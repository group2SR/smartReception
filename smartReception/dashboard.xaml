<Page
    x:Class="smartReception.dashboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    Background="#F1F5F9">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
        <Style TargetType="TextBlock" x:Key="HeaderTextStyle">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Sidebar Button Style -->
        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR NAVIGATION -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sidebar Header -->
            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11" FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Desk Receptionist" Foreground="#64748B" FontSize="12"/>
            </StackPanel>

            <!-- Navigation Links -->
            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#10B981"/>
                </StackPanel.Resources>
                <Button Content="📊  Dashboard" Click="NavDashboard_Click" Style="{StaticResource ActiveSidebarButtonStyle}"/>
                <Button Content="📜  Access Logs" Click="NavAccessControl_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📈  General Reports" Click="NavReports_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📜  System Logs" Click="NavLogs_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="👥  Receptionists" Click="NavReceptionists_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="⚙️  Settings" Click="NavSettings_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>

            <!-- Footer / Log Out -->
            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="🚫  Sign Out" Click="NavLogout_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT area -->
        <Grid Grid.Column="1">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#047857"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="White" Padding="32,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Admin Dashboard" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Welcome back! Manage system configurations and view administrative reports." Foreground="#64748B" FontSize="13"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Padding="32" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="24">
                    <!-- Top Metrics Section -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,12,0" Background="#4F46E5" CornerRadius="12">
                            <StackPanel Padding="20" Spacing="4">
                                <TextBlock Text="TOTAL CLIENTS" FontSize="11" Foreground="White" FontWeight="Bold" Opacity="0.8" CharacterSpacing="50"/>
                                <TextBlock Text="{x:Bind TotalClients, Mode=OneWay}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Margin="6,0,6,0" Background="#10B981" CornerRadius="12">
                            <StackPanel Padding="20" Spacing="4">
                                <TextBlock Text="ACTIVE TODAY" FontSize="11" Foreground="White" FontWeight="Bold" Opacity="0.8" CharacterSpacing="50"/>
                                <TextBlock Text="{x:Bind ActiveToday, Mode=OneWay}" FontSize="36" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Margin="12,0,0,0" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Padding="20" Spacing="4">
                                <TextBlock Text="ENTRIES TODAY" FontSize="11" Foreground="#64748B" FontWeight="Bold" CharacterSpacing="50"/>
                                <TextBlock Text="{x:Bind EntriesToday, Mode=OneWay}" FontSize="36" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Registration Form -->
                    <Border Background="White" Padding="32" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <StackPanel Spacing="16">
                            <TextBlock Text="Register New Client" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,8"/>

                            <!-- Row 1: Names -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="First Name" Style="{StaticResource HeaderTextStyle}"/>
                                    <TextBox x:Name="txtFirst" PlaceholderText="Trevor" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Last Name" Style="{StaticResource HeaderTextStyle}"/>
                                    <TextBox x:Name="txtLast" PlaceholderText="Mac" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                            </Grid>

                            <!-- Row 2: Contact Info -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Email Address" Style="{StaticResource HeaderTextStyle}"/>
                                    <TextBox x:Name="txtEmail" PlaceholderText="trevor@example.com" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Phone Number" Style="{StaticResource HeaderTextStyle}"/>
                                    <TextBox x:Name="txtPhone" PlaceholderText="07..." Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                            </Grid>

                            <!-- Row 3: NIN -->
                            <StackPanel>
                                <TextBlock Text="NIN / ID Number" Style="{StaticResource HeaderTextStyle}"/>
                                <TextBox x:Name="txtNIN" PlaceholderText="CM123..." Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                            </StackPanel>

                            <Grid Margin="0,8,0,0">
                                <Button Content="SAVE CLIENT" Click="btnSubmit_Click" Background="#10B981" Foreground="White" Width="180" Height="42" HorizontalAlignment="Right" FontWeight="Bold" CornerRadius="8"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Activity Log -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="Recent Activity Log" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>
                        <ListView ItemsSource="{x:Bind VisitorLogs}" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" MaxHeight="250" Padding="0,8">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#4F46E5" FontSize="14" FontWeight="Medium" Padding="20,12"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- RIGHT SIDEBAR (ACCESS CONTROL) -->
        <Border Grid.Column="2" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1,0,0,0" Padding="28,32">
            <StackPanel Spacing="24">
                <TextBlock Text="ACCESS CONTROL" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" CharacterSpacing="50"/>

                <Border Background="#1E293B" Padding="20" CornerRadius="12" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel>
                            <TextBlock Text="Client Name / NIN" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox PlaceholderText="Search to verify..." x:Name="txtSearch" Foreground="Black" Height="40" CornerRadius="8" BorderBrush="#475569"/>
                        </StackPanel>
                        <Button Content="VALIDATE ACCESS" Click="btnVerify_Click" HorizontalAlignment="Stretch" Background="#10B981" Foreground="White" FontWeight="Bold" Height="42" CornerRadius="8"/>
                    </StackPanel>
                </Border>

                <Border x:Name="borderFeedback" Visibility="Collapsed" Background="#1E293B" BorderThickness="1" BorderBrush="#334155" Padding="16" CornerRadius="12">
                    <TextBlock x:Name="txtStatusFeedback" TextWrapping="Wrap" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>