<Page
    x:Class="smartReception.dashboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    Background="#F0F0F0">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
        <Style TargetType="TextBox">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#333333" FontWeight="Bold" Margin="0,0,0,5"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" Padding="30">
            <StackPanel Spacing="25">
                <TextBlock Text="CEMENTERS PLAZA - BUILDING ACCESS SYSTEM" 
                           FontSize="28" FontWeight="ExtraBold" Foreground="#1B5E20"/>

                <!-- Top Metrics Section -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,10,0" Background="#2E59D9" CornerRadius="8" Shadow="{StaticResource SharedShadow}">
                        <StackPanel Padding="20">
                            <TextBlock Text="TOTAL CLIENTS" FontSize="12" Foreground="White" FontWeight="Black" Opacity="0.8"/>
                            <TextBlock Text="{x:Bind TotalClients, Mode=OneWay}" FontSize="48" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="5,0,5,0" Background="#1CC88A" CornerRadius="8" Shadow="{StaticResource SharedShadow}">
                        <StackPanel Padding="20">
                            <TextBlock Text="ACTIVE TODAY" FontSize="12" Foreground="White" FontWeight="Black" Opacity="0.8"/>
                            <TextBlock Text="{x:Bind ActiveToday, Mode=OneWay}" FontSize="48" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="10,0,0,0" Background="White" CornerRadius="8" BorderBrush="#E3E6F0" BorderThickness="1" Shadow="{StaticResource SharedShadow}">
                        <StackPanel Padding="20">
                            <TextBlock Text="ENTRIES TODAY" FontSize="12" Foreground="#858796" FontWeight="Black"/>
                            <TextBlock Text="{x:Bind EntriesToday, Mode=OneWay}" FontSize="48" FontWeight="Bold" Foreground="#5A5C69"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Registration Form (UPDATED WITH MISSING FIELDS) -->
                <Border Background="White" Padding="30" CornerRadius="12" BorderBrush="#CCCCCC" BorderThickness="1">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Register New Client" FontSize="20" FontWeight="Bold" Foreground="#000000"/>

                        <!-- Row 1: Names -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Header="First Name" PlaceholderText="e.g. Trevor" x:Name="txtFirst" Margin="0,0,10,0" Foreground="Black"/>
                            <TextBox Header="Last Name" PlaceholderText="e.g. Mac" x:Name="txtLast" Grid.Column="1" Foreground="Black"/>
                        </Grid>

                        <!-- Row 2: Contact Info (Required by DB) -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Header="Email Address" PlaceholderText="trevor@example.com" x:Name="txtEmail" Margin="0,0,10,0" Foreground="Black"/>
                            <TextBox Header="Phone Number" PlaceholderText="07..." x:Name="txtPhone" Grid.Column="1" Foreground="Black"/>
                        </Grid>

                        <!-- Row 3: NIN -->
                        <TextBox Header="NIN / ID Number" PlaceholderText="CM123..." x:Name="txtNIN" Foreground="Black"/>

                        <Button Content="SAVE CLIENT" Click="btnSubmit_Click" Background="#2E7D32" Foreground="White" Width="200" Height="45" HorizontalAlignment="Right" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Activity Log -->
                <TextBlock Text="Recent Activity Log" FontSize="18" FontWeight="Bold" Foreground="#333333"/>
                <ListView ItemsSource="{x:Bind VisitorLogs}" Background="White" CornerRadius="8" BorderBrush="#E3E6F0" BorderThickness="1" MaxHeight="300">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#4e73df" FontSize="14" FontWeight="Medium" Padding="15,10"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>

        <!-- Sidebar Security Check -->
        <Border Grid.Column="1" Background="#1B5E20" Padding="30">
            <StackPanel Spacing="25">
                <TextBlock Text="ACCESS CONTROL" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>

                <StackPanel Background="#26ffffff" Padding="20" CornerRadius="8">
                    <TextBox Header="Client Name" PlaceholderText="Search to verify..." x:Name="txtSearch" Foreground="Black" Margin="0,0,0,15"/>
                    <Button Content="VALIDATE ACCESS" Click="btnVerify_Click" HorizontalAlignment="Stretch" Background="White" Foreground="#1B5E20" FontWeight="Black" Height="45"/>
                </StackPanel>

                <Border x:Name="borderFeedback" Visibility="Collapsed" Background="White" Padding="15" CornerRadius="5">
                    <TextBlock x:Name="txtStatusFeedback" TextWrapping="Wrap" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Page>