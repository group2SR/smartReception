<Page
    x:Class="smartReception.LogOut"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Grid Background="Transparent">
        <!-- Semi-transparent overlay to resemble a modal backdrop if navigated to -->
        <Border Width="440" 
                Height="360" 
                Background="White" 
                CornerRadius="16" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center"
                BorderBrush="#E2E8F0"
                BorderThickness="1">

            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <Grid Padding="36,32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse Width="64" Height="64" Fill="#FEE2E2"/>
                    <FontIcon Glyph="&#xE7E8;" Foreground="#EF4444" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,24" Spacing="8">
                    <TextBlock Text="Sign Out" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#0F172A" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Are you sure you want to sign out of the system?" 
                               FontSize="14" 
                               Foreground="#64748B" 
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Profile Info / Context -->
                <Border Grid.Row="2" 
                        Background="#F8FAFC" 
                        BorderBrush="#E2E8F0" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="16,12" 
                        Margin="0,0,0,24"
                        VerticalAlignment="Top">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <Ellipse Width="44" Height="44" Fill="#E2E8F0"/>
                            <FontIcon Glyph="&#xE77B;" Foreground="#475569" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="Cementers Plaza Session" FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Active User Session" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                            Content="Cancel" 
                            HorizontalAlignment="Stretch" 
                            Height="44"
                            Background="#E2E8F0" 
                            Foreground="#475569" 
                            FontSize="14"
                            FontWeight="SemiBold"
                            CornerRadius="8"
                            x:Name="cancelbtn" Click="cancelbtn_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#CBD5E1"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#334155"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#94A3B8"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#1E293B"/>
                        </Button.Resources>
                    </Button>

                    <Button Grid.Column="2" 
                            HorizontalAlignment="Stretch" 
                            Height="44"
                            Background="#EF4444" 
                            Foreground="White" 
                            CornerRadius="8"
                            x:Name="logoutbtn" Click="logoutbtn_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#DC2626"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#B91C1C"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE7E8;" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sign Out" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>