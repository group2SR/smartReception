<Page
    x:Class="smartReception.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F1F5F9">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0.0"/>
                <GradientStop Color="#064E3B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">

            <Image Source="/Assets/cemlogo_transparent.png" 
                   Height="70" Width="210" 
                   Margin="0,0,0,40" HorizontalAlignment="Center"/>

            <Border CornerRadius="16" 
                    Background="#F8FAFC" 
                    Padding="48,40" 
                    MaxWidth="960"
                    BorderThickness="1"
                    BorderBrush="#E2E8F0">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>

                <Grid ColumnSpacing="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="340" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Section: Reception Access -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="QUICK ACCESS" 
                                   FontWeight="Bold" FontSize="12" 
                                   Foreground="#10B981" Margin="0,0,0,24" CharacterSpacing="100"/>

                        <Grid x:Name="ReceptionCard" 
                              CornerRadius="12" 
                              Background="#FFFFFF" 
                              BorderBrush="#E2E8F0" 
                              BorderThickness="1.5" 
                              Padding="28"
                              Tapped="Grid_Tapped" 
                              PointerEntered="Grid_PointerEntered" 
                              PointerExited="Grid_PointerExited">
                            <StackPanel Spacing="16">
                                <Image Source="/Assets/Admin and receptionist logo designs.png"
                                       Height="150" Stretch="Uniform" HorizontalAlignment="Center"/>
                                <TextBlock Text="RECEPTION DESK"
                                           FontWeight="Bold" FontSize="20"
                                           TextAlignment="Center" Foreground="#0F172A"/>
                                <TextBlock Text="Visitor check-in, registration and instant cloud badge sync"
                                           TextAlignment="Center" FontSize="13"
                                           Foreground="#64748B" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Width="1.5" Fill="#E2E8F0" Margin="0,10"/>

                    <!-- Right Section: Admin Login -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock Text="ADMIN PORTAL" 
                                       FontWeight="Bold" FontSize="12" 
                                       Foreground="#059669" CharacterSpacing="100"/>
                            <TextBlock Text="Administrator Login" 
                                       FontSize="24" FontWeight="Bold" 
                                       Foreground="#0F172A"/>
                            <TextBlock Text="Enter your secure credentials to manage configurations" 
                                       FontSize="13" Foreground="#64748B" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox x:Name="TxtUsername" PlaceholderText="e.g. Admin_Max" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Padding="10,0" VerticalContentAlignment="Center" Foreground="Black"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <PasswordBox x:Name="TxtPassword" PlaceholderText="••••••••" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Padding="10,0" VerticalContentAlignment="Center" Foreground="Black"/>
                        </StackPanel>

                        <Button Content="Sign in to Dashboard"
                                HorizontalAlignment="Stretch"
                                Height="45"
                                Background="#059669" Foreground="White"
                                CornerRadius="8"
                                FontWeight="Bold"
                                x:Name="adminloginbtn" Click="adminloginbtn_Click">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#047857"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#064E3B"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                            </Button.Resources>
                        </Button>

                        <TextBlock x:Name="comment" Text="" TextAlignment="Center" Margin="0,5,0,0" Foreground="#DC2626" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="© 2026 Smart Reception System. All rights reserved." 
                       HorizontalAlignment="Center" 
                       Margin="0,32,0,0" Foreground="#94A3B8" Opacity="0.8" FontSize="12"/>
        </StackPanel>
    </Grid>
</Page>