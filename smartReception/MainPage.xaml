<Page
    x:Class="smartReception.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/b2.png" Stretch="UniformToFill" Opacity="0.8"/>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <Image Source="/Assets/cemlogo_transparent.png" 
                   Height="60" Width="180" 
                   Margin="0,0,0,31" HorizontalAlignment="Center"/>

            <Border CornerRadius="15" 
                    Background="White" 
                    Padding="40" 
                    MaxWidth="1000"
                    BorderThickness="1"
                    BorderBrush="#E5E7EB">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>

                <Grid ColumnSpacing="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Section: Reception Access -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Quick Access" 
                                   FontWeight="Bold" FontSize="14" 
                                   Foreground="Gray" Margin="0,0,0,20"/>

                        <!-- Cursor removed here to fix image_46793c.png errors -->
                        <Grid x:Name="ReceptionCard" 
                              CornerRadius="12" 
                              Background="#F3F4F6" 
                              BorderBrush="LimeGreen" 
                              BorderThickness="1" 
                              Padding="25"
                              Tapped="Grid_Tapped" 
                              PointerEntered="Grid_PointerEntered" 
                              PointerExited="Grid_PointerExited">
                            <StackPanel>
                                <Image Source="/Assets/Admin and receptionist logo designs.png"
                                       Height="140" Stretch="Uniform" Margin="0,0,0,15"/>
                                <TextBlock Text="RECEPTION"
                                           FontWeight="Black" FontSize="20"
                                           TextAlignment="Center" Foreground="#111827"/>
                                <TextBlock Text="Visitor check-in &amp; registration"
                                           TextAlignment="Center" FontSize="13"
                                           Foreground="#6B7280" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Width="1" Fill="#E5E7EB" Margin="0,20"/>

                    <!-- Right Section: Admin Login -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Image Source="/Assets/Minimalist admin logo with icon.png"
                               Height="50" HorizontalAlignment="Left" Margin="0,0,0,10"/>

                        <TextBlock Text="Administrator Login" 
                                   FontSize="22" FontWeight="SemiBold" 
                                   Foreground="#111827" Margin="0,0,0,5"/>
                        <TextBlock Text="Enter credentials to manage clients" 
                                   FontSize="13" Foreground="#6B7280" Margin="0,0,0,25"/>

                        <TextBox Header="Username" PlaceholderText="e.g. Admin_Max" Margin="0,0,0,15"/>
                        <PasswordBox Header="Password" PlaceholderText="••••••••" Margin="0,0,0,25"/>

                        <Button Content="Login to Dashboard"
                                HorizontalAlignment="Stretch"
                                Height="45"
                                Background="LimeGreen" Foreground="White"
                                CornerRadius="6"
                                x:Name="adminloginbtn" Click="adminloginbtn_Click"/>

                        <TextBlock x:Name="comment" Text="" TextAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="© 2026 Smart Reception System" 
                       HorizontalAlignment="Center" 
                       Margin="0,20,0,0" Foreground="White" Opacity="0.6" FontSize="12"/>
        </StackPanel>
    </Grid>
</Page>