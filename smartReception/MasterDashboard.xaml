<Page
    x:Class="smartReception.MasterDashboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
        
        <!-- Sidebar Button Style -->
        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR NAVIGATION -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sidebar Header -->
            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11" FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Central Administration" Foreground="#64748B" FontSize="12"/>
            </StackPanel>

            <!-- Navigation Links -->
            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#10B981"/>
                </StackPanel.Resources>
                <Button Content="📊  Dashboard" Click="NavDashboard_Click" Style="{StaticResource ActiveSidebarButtonStyle}"/>
                <Button Content="📝  Register Clients" Click="NavRegister_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>

            <!-- Footer / Log Out -->
            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="🚪  Sign Out" Click="NavLogout_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN DASHBOARD CONTENT -->
        <Grid Grid.Column="1">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#047857"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Background="White" Padding="32,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Reception Dashboard" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Register visitors and manage entry verification." Foreground="#64748B" FontSize="13"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="20" Padding="14,6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="#10B981" VerticalAlignment="Center"/>
                        <TextBlock Text="SYSTEM ONLINE" Foreground="#047857" FontSize="11" FontWeight="Bold" CharacterSpacing="50"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- STAT CARDS -->
            <Grid Grid.Row="1" Padding="32,24,32,12" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Stat 1: Active Inside -->
                <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20,16">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="ACTIVE INSIDE" FontSize="11" Foreground="#64748B" FontWeight="Bold" CharacterSpacing="50"/>
                            <TextBlock x:Name="TxtStatActive" Text="0" FontSize="32" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#ECFDF5" CornerRadius="10" Width="48" Height="48" VerticalAlignment="Center">
                            <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Stat 2: Total logs today -->
                <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20,16">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="TOTAL ACCESS LOGS" FontSize="11" Foreground="#64748B" FontWeight="Bold" CharacterSpacing="50"/>
                            <TextBlock x:Name="TxtStatLogs" Text="0" FontSize="32" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#EFF6FF" CornerRadius="10" Width="48" Height="48" VerticalAlignment="Center">
                            <TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Stat 3: Deleted records -->
                <Border Grid.Column="2" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="20,16">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="DELETED CLIENTS" FontSize="11" Foreground="#64748B" FontWeight="Bold" CharacterSpacing="50"/>
                            <TextBlock x:Name="TxtStatDeleted" Text="0" FontSize="32" FontWeight="Bold" Foreground="#DC2626"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#FEF2F2" CornerRadius="10" Width="48" Height="48" VerticalAlignment="Center">
                            <TextBlock Text="🗑️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- TOOLBAR / FILTERS -->
            <Grid Grid.Row="2" Padding="32,12" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearchName"
                         Grid.Column="0"
                         PlaceholderText="🔍  Search by name or NIN..."
                         Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                         Padding="12,0" VerticalContentAlignment="Center" Foreground="Black"
                         TextChanged="TxtSearch_TextChanged"/>

                <ComboBox x:Name="CboFilterFloor"
                          Grid.Column="1"
                          SelectedIndex="0"
                          HorizontalAlignment="Stretch" Height="40"
                          CornerRadius="8" BorderBrush="#CBD5E1"
                          SelectionChanged="CboFloor_SelectionChanged" Foreground="Black">
                    <ComboBoxItem Content="All Floors" Tag="All" Foreground="Black"/>
                    <ComboBoxItem Content="1st Floor"  Tag="1" Foreground="Black"/>
                    <ComboBoxItem Content="2nd Floor"  Tag="2" Foreground="Black"/>
                </ComboBox>

                <Button x:Name="BtnRefresh"
                        Grid.Column="2"
                        Content="🔄  Refresh Logs"
                        Background="#059669"
                        Foreground="White"
                        FontSize="13" FontWeight="Bold"
                        Padding="16,0" Height="40"
                        CornerRadius="8"
                        BorderThickness="0"
                        Click="BtnRefresh_Click"/>
            </Grid>

            <!-- MAIN DATA TABS -->
            <Pivot Grid.Row="3" Margin="32,16,32,32" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" RequestedTheme="Light">
                <!-- Active Inside Tab -->
                <PivotItem Header="Active Inside">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FULL NAME" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="0" CharacterSpacing="50"/>
                            <TextBlock Text="NIN" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="1" CharacterSpacing="50"/>
                            <TextBlock Text="FLOOR" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="2" CharacterSpacing="50"/>
                            <TextBlock Text="TIME IN" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="3" CharacterSpacing="50"/>
                            <TextBlock Text="PHONE NUMBER" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="4" CharacterSpacing="50"/>
                            <TextBlock Text="ACTION" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="5" CharacterSpacing="50" HorizontalAlignment="Center"/>
                        </Grid>

                        <ListView x:Name="ActiveClientsListView" Grid.Row="1" SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="24,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="14" Grid.Column="0" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding NIN}" FontSize="13" Grid.Column="1" Foreground="#475569"/>
                                        <TextBlock Text="{Binding FloorName}" FontSize="13" Grid.Column="2" Foreground="#475569"/>
                                        <TextBlock Text="{Binding TimeIn}" FontSize="13" Grid.Column="3" Foreground="#059669" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding PhoneNumber}" FontSize="13" Grid.Column="4" Foreground="#475569"/>
                                        
                                        <Button Grid.Column="5" Content="⏳ Time Out" Tag="{Binding LogId}" Click="BtnTimeOut_Click" 
                                                Background="#FEE2E2" Foreground="#DC2626" BorderThickness="0" CornerRadius="4" 
                                                Padding="8,4" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>

                <!-- Visitor History Tab -->
                <PivotItem Header="General Visitor History">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FULL NAME" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="0" CharacterSpacing="50"/>
                            <TextBlock Text="NIN" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="1" CharacterSpacing="50"/>
                            <TextBlock Text="FLOOR TARGET" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="2" CharacterSpacing="50"/>
                            <TextBlock Text="ACCESS DATE" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="3" CharacterSpacing="50"/>
                            <TextBlock Text="TIME FRAME" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="4" CharacterSpacing="50"/>
                            <TextBlock Text="STATUS" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="5" CharacterSpacing="50"/>
                        </Grid>

                        <ListView x:Name="AllLogsListView" Grid.Row="1" SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="24,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="14" Grid.Column="0" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding NIN}" FontSize="13" Grid.Column="1" Foreground="#475569"/>
                                        <TextBlock Text="{Binding FloorName}" FontSize="13" Grid.Column="2" Foreground="#475569"/>
                                        <TextBlock Text="{Binding AccessDate}" FontSize="13" Grid.Column="3" Foreground="#475569"/>
                                        <TextBlock Text="{Binding TimeInSummary}" FontSize="13" Grid.Column="4" Foreground="#475569"/>
                                        <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="Bold" Grid.Column="5" Foreground="{Binding StatusColor}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>

                <!-- Deleted Records Tab -->
                <PivotItem Header="Deleted Records Archive">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="24,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="3.5*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FULL NAME" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="0" CharacterSpacing="50"/>
                            <TextBlock Text="FLOOR" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="1" CharacterSpacing="50"/>
                            <TextBlock Text="DATE REMOVED" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="2" CharacterSpacing="50"/>
                            <TextBlock Text="REASON FOR REMOVAL" FontSize="11" FontWeight="Bold" Foreground="#475569" Grid.Column="3" CharacterSpacing="50"/>
                        </Grid>

                        <ListView x:Name="DeletedClientsListView" Grid.Row="1" SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="24,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="3.5*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="14" Grid.Column="0" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding FloorName}" FontSize="13" Grid.Column="1" Foreground="#475569"/>
                                        <TextBlock Text="{Binding DeletedDateFormatted}" FontSize="13" Grid.Column="2" Foreground="#475569"/>
                                        <TextBlock Text="{Binding Reason}" FontSize="13" FontStyle="Italic" Grid.Column="3" Foreground="#64748B"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </PivotItem>
            </Pivot>
        </Grid>
    </Grid>
</Page>