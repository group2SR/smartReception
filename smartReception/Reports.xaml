<Page
    x:Class="smartReception.Reports"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />

        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR NAVIGATION -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11" FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Central Administration" Foreground="#64748B" FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#10B981"/>
                </StackPanel.Resources>
                <!-- General Reports is the active page — only this button gets ActiveSidebarButtonStyle -->
                <Button Content="🏠  Master Dashboard" Click="NavMasterDashboard_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📊  Dashboard"        Click="NavDashboard_Click"       Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📜  Access Logs"       Click="NavAccessControl_Click"   Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📈  General Reports"   Click="NavReports_Click"         Style="{StaticResource ActiveSidebarButtonStyle}"/>
                <Button Content="📜  System Logs"       Click="NavLogs_Click"            Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="👥  Receptionists"     Click="NavReceptionists_Click"   Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="⚙️  Settings"          Click="NavSettings_Click"        Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="🚪  Sign Out" Click="NavLogout_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#047857"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="White"/>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="White" Padding="32,20"
                  BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="General Reports" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Generate system-wide analytics, filter visitor statistics and export audit documents"
                               Foreground="#64748B" FontSize="13"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="32" Spacing="24">

                    <!-- ── Statistics Cards ─────────────────────────────── -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="16"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Ellipse Width="32" Height="32" Fill="#EFF6FF" HorizontalAlignment="Left"/>
                                <TextBlock Text="Total Clients" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TotalClientsText" Text="—" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="16"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Ellipse Width="32" Height="32" Fill="#ECFDF5" HorizontalAlignment="Left"/>
                                <TextBlock Text="Active Clients" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="ActiveClientsText" Text="—" FontSize="24" FontWeight="Bold" Foreground="#047857"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="16"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Ellipse Width="32" Height="32" Fill="#FEF2F2" HorizontalAlignment="Left"/>
                                <TextBlock Text="Deleted Clients" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DeletedClientsText" Text="—" FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Background="White" CornerRadius="12" Padding="16"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Ellipse Width="32" Height="32" Fill="#F5F3FF" HorizontalAlignment="Left"/>
                                <TextBlock Text="Today's Logins" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TodayLoginsText" Text="—" FontSize="24" FontWeight="Bold" Foreground="#6D28D9"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="White" CornerRadius="12" Padding="16"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Ellipse Width="32" Height="32" Fill="#FEF9C3" HorizontalAlignment="Left"/>
                                <TextBlock Text="Receptionists" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="ReceptionistsText" Text="—" FontSize="24" FontWeight="Bold" Foreground="#854D0E"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="5" Background="White" CornerRadius="12" Padding="16"
                                BorderBrush="#E2E8F0" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Ellipse Width="32" Height="32" Fill="#FEF2F2" HorizontalAlignment="Left"/>
                                <TextBlock Text="Blocked Users" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                                <TextBlock x:Name="BlockedUsersText" Text="—" FontSize="24" FontWeight="Bold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── Configure Report Scope ───────────────────────── -->
                    <Border Background="White" CornerRadius="12" Padding="24"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="20">
                            <TextBlock Text="Configure Report Scope" FontSize="18" FontWeight="Bold" Foreground="#0F172A"/>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Report Type -->
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Report Type" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <ComboBox x:Name="ReportTypeCombo" Height="40" SelectedIndex="0"
                                              HorizontalAlignment="Stretch" CornerRadius="8"
                                              BorderBrush="#CBD5E1" Foreground="Black">
                                        <ComboBoxItem Content="Access Logs Report" Foreground="Black"/>
                                        <ComboBoxItem Content="Deleted Clients"    Foreground="Black"/>
                                        <ComboBoxItem Content="Blocked Users"      Foreground="Black"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Start Date -->
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Start Date" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <DatePicker x:Name="StartDatePicker" Height="40"
                                                HorizontalAlignment="Stretch" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                </StackPanel>

                                <!-- End Date -->
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="End Date" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <DatePicker x:Name="EndDatePicker" Height="40"
                                                HorizontalAlignment="Stretch" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                </StackPanel>

                                <!-- Floor Target -->
                                <StackPanel Grid.Column="3" Spacing="6">
                                    <TextBlock Text="Floor Target" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <ComboBox x:Name="FloorCombo" Height="40" SelectedIndex="0"
                                              HorizontalAlignment="Stretch" CornerRadius="8"
                                              BorderBrush="#CBD5E1" Foreground="Black">
                                        <ComboBoxItem Content="All Floors" Foreground="Black"/>
                                        <ComboBoxItem Content="1st Floor"  Foreground="Black"/>
                                        <ComboBoxItem Content="2nd Floor"  Foreground="Black"/>
                                        <ComboBoxItem Content="3rd Floor"  Foreground="Black"/>
                                        <ComboBoxItem Content="4th Floor"  Foreground="Black"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Generate Button -->
                                <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                    <Button x:Name="GenerateReportBtn"
                                            Content="⚡ Generate Report"
                                            Click="GenerateReport_Click"
                                            Height="40" Background="#059669" Foreground="White"
                                            FontWeight="Bold" CornerRadius="8"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>

                            <!-- Status text -->
                            <TextBlock x:Name="StatusText" Text="" Foreground="#64748B"
                                       FontSize="13" Visibility="Collapsed"/>

                            <!-- Export Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        Spacing="12" Margin="0,10,0,0">
                                <Button x:Name="ExportPdfBtn"
                                        Content="📄 Export PDF" Click="ExportPdf_Click"
                                        Background="#1E293B" Foreground="White"
                                        Padding="20,10" Height="40" CornerRadius="8"/>
                                <Button x:Name="ExportExcelBtn"
                                        Content="📊 Export Excel" Click="ExportExcel_Click"
                                        Background="#1E293B" Foreground="White"
                                        Padding="20,10" Height="40" CornerRadius="8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Generated Data Matrix ────────────────────────── -->
                    <Border Background="White" CornerRadius="12" Padding="24"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Generated Data Matrix" FontSize="18"
                                       FontWeight="Bold" Foreground="#0F172A"/>

                            <!-- Table Header -->
                            <Grid Background="#F8FAFC" Padding="16,12"
                                  BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="1.3*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="TYPE"        FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                <TextBlock Grid.Column="1" Text="LOG ID"      FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                <TextBlock Grid.Column="2" Text="NAME"        FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                <TextBlock Grid.Column="3" Text="FLOOR"       FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                <TextBlock Grid.Column="4" Text="ACCESS DATE" FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                <TextBlock Grid.Column="5" Text="TIME IN"     FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                <TextBlock Grid.Column="6" Text="TIME OUT"    FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                <TextBlock Grid.Column="7" Text="STATUS"      FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                            </Grid>

                            <!-- Data rows -->
                            <ListView x:Name="ReportListView" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:ReportRow">
                                        <Grid Padding="16,10" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.3*"/>
                                                <ColumnDefinition Width="1.3*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- TYPE badge -->
                                            <Border Grid.Column="0" CornerRadius="4" Padding="6,3"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="{x:Bind RowTypeBadgeColor}">
                                                <TextBlock Text="{x:Bind RowType}"
                                                           FontSize="10" FontWeight="Bold"
                                                           Foreground="{x:Bind RowTypeBadgeTextColor}"/>
                                            </Border>

                                            <TextBlock Grid.Column="1" Text="{x:Bind LogId}"
                                                       FontSize="12" Foreground="#64748B"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2" Text="{x:Bind ClientName}"
                                                       FontSize="13" Foreground="#0F172A"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3" Text="{x:Bind FloorTarget}"
                                                       FontSize="13" Foreground="#475569"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="4" Text="{x:Bind AccessDate}"
                                                       FontSize="13" Foreground="#475569"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="5" Text="{x:Bind TimeIn}"
                                                       FontSize="13" Foreground="#475569"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="6" Text="{x:Bind TimeOut}"
                                                       FontSize="13" Foreground="#475569"
                                                       VerticalAlignment="Center"/>

                                            <!-- STATUS badge -->
                                            <Border Grid.Column="7" CornerRadius="4" Padding="8,3"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="{x:Bind StatusColor}">
                                                <TextBlock Text="{x:Bind Status}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{x:Bind StatusTextColor}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Footer / Pagination -->
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="PaginationInfoText"
                                           Text="Showing 0 to 0 of 0 logs generated"
                                           VerticalAlignment="Center" Foreground="#64748B" FontSize="13"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="PrevPageBtn" Content="&lt;" Width="36" Height="36"
                                            CornerRadius="8" Click="PrevPage_Click"/>
                                    <Button x:Name="CurrentPageBtn" Content="1" Width="36" Height="36"
                                            Background="#059669" Foreground="White" CornerRadius="8"/>
                                    <Button x:Name="NextPageBtn" Content="&gt;" Width="36" Height="36"
                                            CornerRadius="8" Click="NextPage_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
