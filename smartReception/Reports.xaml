<Page
    x:Class="smartReception.Reports"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F5F6FA">


    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Padding="20" Spacing="20">

            <!-- Header -->
            <TextBlock Text="Reports"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>

            <!-- Statistics Cards -->
            <Grid ColumnSpacing="12">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1 -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="10"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <Ellipse Width="40"
                                 Height="40"
                                 Fill="#2563EB"/>

                        <TextBlock Text="Total Clients"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="#6B7280"/>

                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Card 2 -->
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <Ellipse Width="40"
                                 Height="40"
                                 Fill="#16A34A"/>

                        <TextBlock Text="Active Clients"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="#6B7280"/>

                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Card 3 -->
                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="10"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <Ellipse Width="40"
                                 Height="40"
                                 Fill="#EF4444"/>

                        <TextBlock Text="Deleted Clients"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="#6B7280"/>

                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Card 4 -->
                <Border Grid.Column="3"
                        Background="White"
                        CornerRadius="10"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <Ellipse Width="40"
                                 Height="40"
                                 Fill="#9333EA"/>

                        <TextBlock Text="Today's Accesses"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="#6B7280"/>

                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Card 5 -->
                <Border Grid.Column="4"
                        Background="White"
                        CornerRadius="10"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <Ellipse Width="40"
                                 Height="40"
                                 Fill="#EAB308"/>

                        <TextBlock Text="Receptionists"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="#6B7280"/>

                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Card 6 -->
                <Border Grid.Column="5"
                        Background="White"
                        CornerRadius="10"
                        Padding="15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <Ellipse Width="40"
                                 Height="40"
                                 Fill="#F97316"/>

                        <TextBlock Text="Blocked Users"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="#6B7280"/>

                        <TextBlock Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#DC2626"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Generate Report -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel Spacing="18">

                    <TextBlock Text="Generate Report"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <Grid ColumnSpacing="12">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Report Type -->
                        <StackPanel Grid.Column="0"
                                    Spacing="5">

                            <TextBlock Text="Report Type"
                                       FontSize="13"/>

                            <ComboBox Height="40"
                                      SelectedIndex="0">

                                <ComboBoxItem Content="Access Logs Report"/>
                                <ComboBoxItem Content="Deleted Clients"/>
                                <ComboBoxItem Content="Blocked Users"/>

                            </ComboBox>
                        </StackPanel>

                        <!-- Start Date -->
                        <StackPanel Grid.Column="1"
                                    Spacing="5">

                            <TextBlock Text="Start Date"
                                       FontSize="13"/>

                            <DatePicker Height="40"/>
                        </StackPanel>

                        <!-- End Date -->
                        <StackPanel Grid.Column="2"
                                    Spacing="5">

                            <TextBlock Text="End Date"
                                       FontSize="13"/>

                            <DatePicker Height="40"/>
                        </StackPanel>

                        <!-- Floor -->
                        <StackPanel Grid.Column="3"
                                    Spacing="5">

                            <TextBlock Text="Floor"
                                       FontSize="13"/>

                            <ComboBox Height="40"
                                      SelectedIndex="0">

                                <ComboBoxItem Content="All Floors"/>
                                <ComboBoxItem Content="1st Floor"/>
                                <ComboBoxItem Content="2nd Floor"/>
                                <ComboBoxItem Content="3rd Floor"/>

                            </ComboBox>
                        </StackPanel>

                        <!-- Generate Button -->
                        <StackPanel Grid.Column="4"
                                    VerticalAlignment="Bottom">

                            <Button Content="Generate"
                                    Height="40"
                                    Background="#2563EB"
                                    Foreground="White"/>
                        </StackPanel>
                    </Grid>

                    <!-- Export Buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10">

                        <Button Content="Export PDF"
                                Background="#16A34A"
                                Foreground="White"
                                Padding="20,10"/>

                        <Button Content="Export Excel"
                                Background="#15803D"
                                Foreground="White"
                                Padding="20,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Report Results -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel Spacing="15">

                    <TextBlock Text="Report Results"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <!-- Table Header -->
                    <Grid Background="#F3F4F6"
                          Padding="12">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Log ID"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Column="1"
                                   Text="Client Name"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Column="2"
                                   Text="Floor"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Column="3"
                                   Text="Date"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Column="4"
                                   Text="Time In"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Column="5"
                                   Text="Time Out"
                                   FontWeight="Bold"/>

                        <TextBlock Grid.Column="6"
                                   Text="Status"
                                   FontWeight="Bold"/>
                    </Grid>

                    <!-- Rows -->
                    <ListView>



                    </ListView>

                    <!-- Footer -->
                    <Grid Margin="0,10,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Showing 1 to 5 of 142 entries"
                                   VerticalAlignment="Center"
                                   Foreground="#6B7280"/>

                        <!-- Pagination -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="6">

                            <Button Content="&lt;"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="1"
                                    Width="35"
                                    Height="35"
                                    Background="#2563EB"
                                    Foreground="White"/>

                            <Button Content="2"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="3"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="4"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="5"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="&gt;"
                                    Width="35"
                                    Height="35"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
