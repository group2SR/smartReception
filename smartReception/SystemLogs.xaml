<Page
    x:Class="smartReception.SystemLogs"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Page.Resources>
        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
        <Style TargetType="Button" x:Key="TabButtonStyle">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style TargetType="Button" x:Key="ActiveTabButtonStyle" BasedOn="{StaticResource TabButtonStyle}">
            <Setter Property="Foreground" Value="#10B981"/>
            <Setter Property="BorderBrush" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11" FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Central Administration" Foreground="#64748B" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#10B981"/>
                </StackPanel.Resources>
                <Button Content="📊  Dashboard"       Click="NavDashboard_Click"     Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📜  Access Logs"     Click="NavAccessControl_Click"  Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📈  General Reports" Click="NavReports_Click"        Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📜  System Logs"     Click="NavLogs_Click"           Style="{StaticResource ActiveSidebarButtonStyle}"/>
                <Button Content="👥  Receptionists"   Click="NavReceptionists_Click"  Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="⚙️  Settings"        Click="NavSettings_Click"       Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="🚪  Sign Out" Click="NavLogout_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="White" Padding="32,20"
                  BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="System Logs" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Monitor receptionist sessions, sign-in/out times, and all system activity"
                               Foreground="#64748B" FontSize="13"/>
                </StackPanel>
                <Button x:Name="ExportBtn" Grid.Column="1" VerticalAlignment="Center"
                        Content="📤 Export Log" Background="#1E293B" Foreground="White"
                        Padding="20,10" Height="40" CornerRadius="8" Click="ExportBtn_Click"/>
            </Grid>

            <!-- Stats Bar -->
            <Grid Grid.Row="1" Background="White" Padding="32,0,32,0"
                  BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <!-- Total Sessions -->
                    <Border Padding="0,16,40,16">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="StatTotalSessions" Text="0"
                                       FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>
                            <TextBlock Text="Total Sessions" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                    <Rectangle Width="1" Fill="#E2E8F0" Margin="0,12"/>
                    <!-- Active Now -->
                    <Border Padding="40,16">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="StatActiveNow" Text="0"
                                       FontSize="28" FontWeight="Bold" Foreground="#10B981"/>
                            <TextBlock Text="Currently Active" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                    <Rectangle Width="1" Fill="#E2E8F0" Margin="0,12"/>
                    <!-- Avg Duration -->
                    <Border Padding="40,16">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="StatAvgDuration" Text="—"
                                       FontSize="28" FontWeight="Bold" Foreground="#3B82F6"/>
                            <TextBlock Text="Avg Session Length" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                    <Rectangle Width="1" Fill="#E2E8F0" Margin="0,12"/>
                    <!-- Today's Logins -->
                    <Border Padding="40,16">
                        <StackPanel Spacing="2">
                            <TextBlock x:Name="StatTodayLogins" Text="0"
                                       FontSize="28" FontWeight="Bold" Foreground="#8B5CF6"/>
                            <TextBlock Text="Logins Today" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="32" Spacing="20">

                    <!-- Filters Card -->
                    <Border Background="White" CornerRadius="12" Padding="20"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Filter Logs" FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="5">
                                    <TextBlock Text="SEARCH RECEPTIONIST" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <TextBox x:Name="SearchBox" Height="40" CornerRadius="8"
                                             BorderBrush="#CBD5E1" PlaceholderText="Name or username…"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="5">
                                    <TextBlock Text="ACTIVITY" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <ComboBox x:Name="ActivityFilter" Height="40" SelectedIndex="0"
                                              CornerRadius="8" BorderBrush="#CBD5E1"
                                              HorizontalAlignment="Stretch" Foreground="Black">
                                        <ComboBoxItem Content="All Activities" Foreground="Black"/>
                                        <ComboBoxItem Content="Login"           Foreground="Black"/>
                                        <ComboBoxItem Content="Logout"          Foreground="Black"/>
                                        <ComboBoxItem Content="Access Log"      Foreground="Black"/>
                                        <ComboBoxItem Content="Generate Report" Foreground="Black"/>
                                        <ComboBoxItem Content="Backup Database" Foreground="Black"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="5">
                                    <TextBlock Text="FROM DATE" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <DatePicker x:Name="StartDatePicker" Height="40"
                                                HorizontalAlignment="Stretch" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Spacing="5">
                                    <TextBlock Text="TO DATE" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                    <DatePicker x:Name="EndDatePicker" Height="40"
                                                HorizontalAlignment="Stretch" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                                    <Button Content="🔍 Filter" Height="40"
                                            Background="#059669" Foreground="White"
                                            FontWeight="Bold" CornerRadius="8"
                                            HorizontalAlignment="Stretch"
                                            Click="ApplyFilters_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Status / Error Banner -->
                    <Border x:Name="StatusBanner" CornerRadius="8" Padding="16,12" Visibility="Collapsed">
                        <TextBlock x:Name="StatusText" FontSize="13"/>
                    </Border>

                    <!-- Tab switcher: Sessions | All Events -->
                    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                        <StackPanel>
                            <!-- Tabs -->
                            <StackPanel Orientation="Horizontal" Padding="16,0" Spacing="0"
                                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                <StackPanel.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#059669"/>
                                </StackPanel.Resources>
                                <Button x:Name="TabSessions" Content="👤  Sessions View"
                                        Style="{StaticResource ActiveTabButtonStyle}"
                                        Click="TabSessions_Click"/>
                                <Button x:Name="TabAllEvents" Content="📋  All Events"
                                        Style="{StaticResource TabButtonStyle}"
                                        Click="TabAllEvents_Click"/>
                            </StackPanel>

                            <!-- ══ SESSIONS VIEW ══ -->
                            <StackPanel x:Name="SessionsPanel" Padding="0,0,0,0">
                                <!-- Table header -->
                                <Grid Background="#F8FAFC" Padding="20,12"
                                      BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="RECEPTIONIST"  FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="1" Text="ROLE"       FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="2" Text="DATE"       FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="3" Text="SIGN IN"    FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="4" Text="SIGN OUT"   FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="5" Text="DURATION"   FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="6" Text="STATUS"     FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                </Grid>

                                <ListView x:Name="SessionsListView" SelectionMode="None" IsItemClickEnabled="False">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:ReceptionistSession">
                                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="20,14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2.5*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.4*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="1.3*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Name + Avatar -->
                                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                                        <Border Width="36" Height="36" CornerRadius="18" Background="#0369A1">
                                                            <TextBlock Text="{x:Bind Initials}" FontSize="12" FontWeight="Bold"
                                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{x:Bind ReceptionistName}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="#0F172A" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <!-- Role badge -->
                                                    <Border Grid.Column="1" CornerRadius="6" Padding="10,4"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{x:Bind RoleBadgeColor}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{x:Bind Role}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>

                                                    <!-- Date -->
                                                    <TextBlock Grid.Column="2" Text="{x:Bind Date}"
                                                               FontSize="13" Foreground="#475569" VerticalAlignment="Center"/>

                                                    <!-- Sign In -->
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                Spacing="6" VerticalAlignment="Center">
                                                        <Ellipse Width="8" Height="8" Fill="#10B981"/>
                                                        <TextBlock Text="{x:Bind TimeIn}" FontSize="13"
                                                                   FontWeight="SemiBold" Foreground="#0F172A"/>
                                                    </StackPanel>

                                                    <!-- Sign Out -->
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                                Spacing="6" VerticalAlignment="Center">
                                                        <Ellipse Width="8" Height="8" Fill="#EF4444"/>
                                                        <TextBlock Text="{x:Bind TimeOutDisplay}" FontSize="13"
                                                                   Foreground="#475569"/>
                                                    </StackPanel>

                                                    <!-- Duration -->
                                                    <TextBlock Grid.Column="5" Text="{x:Bind Duration}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#3B82F6" VerticalAlignment="Center"/>

                                                    <!-- Status badge -->
                                                    <Border Grid.Column="6" CornerRadius="6" Padding="10,4"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{x:Bind StatusColor}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{x:Bind Status}" FontSize="11"
                                                                   FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Sessions empty state -->
                                <Border x:Name="SessionsEmpty" Padding="40" Visibility="Collapsed">
                                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                                        <TextBlock Text="📭" FontSize="40" HorizontalAlignment="Center"/>
                                        <TextBlock Text="No sessions found" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="#475569" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Try adjusting your filters or date range."
                                                   FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ══ ALL EVENTS VIEW ══ -->
                            <StackPanel x:Name="EventsPanel" Visibility="Collapsed">
                                <!-- Table header -->
                                <Grid Background="#F8FAFC" Padding="20,12"
                                      BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.1*"/>
                                        <ColumnDefinition Width="1.3*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="1.6*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ID"          FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="1" Text="ACTOR"       FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="2" Text="ROLE"        FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="3" Text="ACTIVITY"    FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="4" Text="DESCRIPTION" FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                    <TextBlock Grid.Column="5" Text="DATE &amp; TIME" FontWeight="Bold" FontSize="11" Foreground="#475569"/>
                                </Grid>

                                <ListView x:Name="LogsListView" SelectionMode="None" IsItemClickEnabled="False">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:SystemLogModel">
                                            <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="20,14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1.1*"/>
                                                        <ColumnDefinition Width="1.3*"/>
                                                        <ColumnDefinition Width="3*"/>
                                                        <ColumnDefinition Width="1.6*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{x:Bind SystemLogId}" FontSize="12"
                                                               Foreground="#94A3B8" VerticalAlignment="Center"/>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                Spacing="10" VerticalAlignment="Center">
                                                        <Border Width="34" Height="34" CornerRadius="17" Background="#10B981">
                                                            <TextBlock Text="{x:Bind Initials}" FontSize="12" FontWeight="Bold"
                                                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{x:Bind Actor}" FontSize="13" Foreground="#0F172A"
                                                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <Border Grid.Column="2" CornerRadius="6" Padding="10,4"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{x:Bind RoleBadgeColor}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{x:Bind Role}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                                    </Border>

                                                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                Spacing="6" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind ActivityIcon}" FontSize="13"/>
                                                        <Border CornerRadius="6" Padding="8,3">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="{x:Bind ActivityBadgeColor}"/>
                                                            </Border.Background>
                                                            <TextBlock Text="{x:Bind Activity}" FontSize="11"
                                                                       FontWeight="SemiBold" Foreground="White"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="4" Text="{x:Bind Description}" FontSize="13"
                                                               Foreground="#475569" VerticalAlignment="Center" TextWrapping="Wrap"/>

                                                    <TextBlock Grid.Column="5" Text="{x:Bind FormattedDate}" FontSize="12"
                                                               Foreground="#64748B" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Events empty state -->
                                <Border x:Name="EventsEmpty" Padding="40" Visibility="Collapsed">
                                    <StackPanel HorizontalAlignment="Center" Spacing="8">
                                        <TextBlock Text="📭" FontSize="40" HorizontalAlignment="Center"/>
                                        <TextBlock Text="No events found" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="#475569" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Try adjusting your filters."
                                                   FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Pagination -->
                            <Grid Padding="20,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PaginationLabel" Text="Showing 0 of 0 entries"
                                           VerticalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                    <Button x:Name="PrevBtn" Content="&lt;" Width="36" Height="36"
                                            CornerRadius="8" Click="PrevBtn_Click"/>
                                    <Button x:Name="PageBtn" Content="1" Width="36" Height="36"
                                            Background="#059669" Foreground="White" CornerRadius="8"/>
                                    <Button x:Name="NextBtn" Content="&gt;" Width="36" Height="36"
                                            CornerRadius="8" Click="NextBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
