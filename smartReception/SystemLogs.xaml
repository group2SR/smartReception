<Page
    x:Class="smartReception.SystemLogs"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">


    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Padding="20"
                    Spacing="20">

            <!-- Page Title -->
            <TextBlock Text="System Logs"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>

            <!-- Main Container -->
            <Border Background="White"
                    CornerRadius="10"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel Spacing="20">

                    <!-- Header -->
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Filter Logs"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1"
                                Content="Export Logs"
                                Background="#2563EB"
                                Foreground="White"
                                Padding="20,10"/>
                    </Grid>

                    <!-- Filters -->
                    <Grid ColumnSpacing="12">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search User -->
                        <StackPanel Grid.Column="0"
                                    Spacing="5">

                            <TextBlock Text="Search User"
                                       FontSize="13"
                                       Foreground="#374151"/>

                            <TextBox Height="40"
                                     PlaceholderText="Search by user name..."/>
                        </StackPanel>

                        <!-- Activity -->
                        <StackPanel Grid.Column="1"
                                    Spacing="5">

                            <TextBlock Text="Activity"
                                       FontSize="13"
                                       Foreground="#374151"/>

                            <ComboBox Height="40"
                                      SelectedIndex="0">

                                <ComboBoxItem Content="All Activities"/>
                                <ComboBoxItem Content="Login"/>
                                <ComboBoxItem Content="Logout"/>
                                <ComboBoxItem Content="Access Log"/>
                                <ComboBoxItem Content="Generate Report"/>
                                <ComboBoxItem Content="Backup Database"/>

                            </ComboBox>
                        </StackPanel>

                        <!-- Start Date -->
                        <StackPanel Grid.Column="2"
                                    Spacing="5">

                            <TextBlock Text="Start Date"
                                       FontSize="13"
                                       Foreground="#374151"/>

                            <DatePicker Height="40"/>
                        </StackPanel>

                        <!-- End Date -->
                        <StackPanel Grid.Column="3"
                                    Spacing="5">

                            <TextBlock Text="End Date"
                                       FontSize="13"
                                       Foreground="#374151"/>

                            <DatePicker Height="40"/>
                        </StackPanel>

                        <!-- Search Button -->
                        <StackPanel Grid.Column="4"
                                    VerticalAlignment="Bottom">

                            <Button Content="Search"
                                    Height="40"
                                    Background="#2563EB"
                                    Foreground="White"
                                    FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <!-- Table -->
                    <Border BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8">

                        <StackPanel>

                            <!-- Table Header -->
                            <Grid Background="#F3F4F6"
                                  Padding="12">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Log ID"
                                           FontWeight="Bold"/>

                                <TextBlock Grid.Column="1"
                                           Text="User"
                                           FontWeight="Bold"/>

                                <TextBlock Grid.Column="2"
                                           Text="Role"
                                           FontWeight="Bold"/>

                                <TextBlock Grid.Column="3"
                                           Text="Activity"
                                           FontWeight="Bold"/>

                                <TextBlock Grid.Column="4"
                                           Text="Description"
                                           FontWeight="Bold"/>

                                <TextBlock Grid.Column="5"
                                           Text="Date &amp; Time"
                                           FontWeight="Bold"/>
                            </Grid>

                            <!-- Log Rows -->
                            <ListView BorderThickness="0">

                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Footer -->
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Showing 1 to 5 of 0 entries"
                                   VerticalAlignment="Center"
                                   Foreground="#6B7280"/>

                        <!-- Pagination -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="6">

                            <Button Content="&lt;"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="1"
                                    Width="35"
                                    Height="35"
                                    Background="#2563EB"
                                    Foreground="White"/>

                            <Button Content="2"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="3"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="4"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="5"
                                    Width="35"
                                    Height="35"/>

                            <Button Content="&gt;"
                                    Width="35"
                                    Height="35"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <Button Content="Create Receptionist"
                    Background="#2563EB"
                    Foreground="White"
                    Padding="20,10"
                    HorizontalAlignment="Left"
                    CornerRadius="10"
                    x:Name="createreceptionistbtn" Click="createreceptionistbtn_Click"/>
            <AppBarButton
                       Icon="Back"
                      
                       Padding="20,10"
                       HorizontalAlignment="Left"
                       CornerRadius="10"
                        Background="#2563EB"
                         Foreground="White"
                       x:Name="systemlogs" Click="systemlogs_Click"/>
        </StackPanel>

    </ScrollViewer>
   
</Page>
