<Page
    x:Class="smartReception.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">


    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <StackPanel Padding="20"
                    Spacing="20">

            <!-- Page Title -->
            <TextBlock Text="Settings"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="#1F2937"/>

            <!-- Top Grid -->
            <Grid ColumnSpacing="12"
                  RowSpacing="12">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Administrator Account -->
                <Border Grid.Row="0"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="10"
                        Padding="18"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel Spacing="12">

                        <TextBlock Text="Administrator Account"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <!-- Full Name -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="Full Name"
                                       FontSize="13"/>

                            <TextBox Text="Administrator"
                                     Height="38"/>
                        </StackPanel>

                        <!-- Username -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="Username"
                                       FontSize="13"/>

                            <TextBox Text="admin"
                                     Height="38"/>
                        </StackPanel>

                        <!-- Email -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="Email"
                                       FontSize="13"/>

                            <TextBox Text="admin@building.com"
                                     Height="38"/>
                        </StackPanel>

                        <!-- Button -->
                        <Button Content="Save Changes"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Change Password -->
                <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="18"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel Spacing="12">

                        <TextBlock Text="Change Password"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <!-- Current Password -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="Current Password"
                                       FontSize="13"/>

                            <PasswordBox Height="38"
                                         Password="12345678"/>
                        </StackPanel>

                        <!-- New Password -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="New Password"
                                       FontSize="13"/>

                            <PasswordBox Height="38"
                                         Password="12345678"/>
                        </StackPanel>

                        <!-- Confirm Password -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="Confirm Password"
                                       FontSize="13"/>

                            <PasswordBox Height="38"
                                         Password="12345678"/>
                        </StackPanel>

                        <!-- Button -->
                        <Button Content="Update Password"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- Security Settings -->
                <Border Grid.Row="0"
                        Grid.Column="2"
                        Background="White"
                        CornerRadius="10"
                        Padding="18"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel Spacing="12">

                        <TextBlock Text="Security Settings"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <CheckBox Content="Require Strong Passwords"
                                  IsChecked="True"/>

                        <CheckBox Content="Allow Receptionist Password Reset"
                                  IsChecked="True"/>

                        <CheckBox Content="Enable Login Audit Trail"
                                  IsChecked="True"/>

                        <CheckBox Content="Auto Logout After Inactivity"/>

                        <!-- Timeout -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="Inactivity Timeout (minutes)"
                                       FontSize="13"/>

                            <ComboBox Height="38"
                                      SelectedIndex="0">

                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="60"/>
                                <ComboBoxItem Content="90"/>
                                <ComboBoxItem Content="120"/>

                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Database Settings -->
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="10"
                        Padding="18"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel Spacing="12">

                        <TextBlock Text="Database Settings"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <!-- Server Name -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="Server Name"
                                       FontSize="13"/>

                            <TextBox Text="DESKTOP-SERVER"
                                     Height="38"/>
                        </StackPanel>

                        <!-- Database Name -->
                        <StackPanel Spacing="5">

                            <TextBlock Text="Database Name"
                                       FontSize="13"/>

                            <TextBox Text="BuildingAccessDB"
                                     Height="38"/>
                        </StackPanel>

                        <!-- Button -->
                        <Button Content="Test Connection"
                                Height="38"
                                Background="#2563EB"
                                Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Backup & Restore -->
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Background="White"
                        CornerRadius="10"
                        Padding="18"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel Spacing="15">

                        <TextBlock Text="Backup &amp; Restore"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Backup your database regularly to prevent data loss."
                                   TextWrapping="Wrap"
                                   Foreground="#6B7280"/>

                        <!-- Backup Button -->
                        <Button Content="Backup Database"
                                Height="40"
                                Background="#16A34A"
                                Foreground="White"
                                FontWeight="SemiBold"/>

                        <!-- Restore Button -->
                        <Button Content="Restore Database"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <!-- System Information -->
                <Border Grid.Row="1"
                        Grid.Column="2"
                        Background="White"
                        CornerRadius="10"
                        Padding="18"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel Spacing="12">

                        <TextBlock Text="System Information"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Grid RowSpacing="10">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="System Name:"
                                       Foreground="#6B7280"/>

                            <TextBlock Grid.Column="1"
                                       Margin="10,0,0,0"
                                       Text="Smart Reception System"/>

                            <TextBlock Grid.Row="1"
                                       Text="Version:"
                                       Foreground="#6B7280"/>

                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="10,0,0,0"
                                       Text="1.0.0"/>

                            <TextBlock Grid.Row="2"
                                       Text="Database:"
                                       Foreground="#6B7280"/>

                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="10,0,0,0"
                                       Text="SQL Server"/>

                            <TextBlock Grid.Row="3"
                                       Text="Developer:"
                                       Foreground="#6B7280"/>

                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Margin="10,0,0,0"
                                       Text="Administrator"/>
                        </Grid>

                        <TextBlock Text="© 2025 All Rights Reserved"
                                   Margin="0,10,0,0"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Save Button -->
            <StackPanel HorizontalAlignment="Center" Spacing="10">

                <Button Content="Save Settings"
                        Width="220"
                        Height="45"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="SemiBold"/>
                <Button Content="logout" HorizontalAlignment="Center"
                        Background="PaleVioletRed"
                        Foreground="White"
                        x:Name="logoutbtn" Click="logoutbtn_Click"/>
                <AppBarButton Icon="Back" Label="back" HorizontalAlignment="Left" Background="#2563EB" Foreground="White" CornerRadius="10"
                              x:Name="settingsbackbtn" Click="settingsbackbtn_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
