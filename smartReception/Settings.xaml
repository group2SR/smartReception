<Page
    x:Class="smartReception.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,28,32,40" Spacing="24">

            <!-- Page Header -->
            <StackPanel Spacing="4">
                <TextBlock Text="Settings"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#0F172A"/>
                <TextBlock Text="Manage your account, security and system preferences."
                           FontSize="14"
                           Foreground="#64748B"/>
            </StackPanel>

            <!-- Row 1 -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Administrator Account -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="12"
                        Padding="24"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Administrator Account"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"/>
                            <TextBlock Text="Update your display name and login username."
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#F1F5F9"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Full Name"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>
                            <TextBox x:Name="TxtAdminFullName"
                                     PlaceholderText="Loading..."
                                     Height="40"
                                     FontSize="14"
                                     BorderBrush="#CBD5E1"
                                     BorderThickness="1"
                                     CornerRadius="6"
                                     Padding="10,0"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Username"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>
                            <TextBox x:Name="TxtAdminUsername"
                                     PlaceholderText="Loading..."
                                     Height="40"
                                     FontSize="14"
                                     BorderBrush="#CBD5E1"
                                     BorderThickness="1"
                                     CornerRadius="6"
                                     Padding="10,0"/>
                        </StackPanel>
                        <Button Content="Save Changes"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="14"
                                CornerRadius="6"
                                Click="BtnSaveAccount_Click"/>
                    </StackPanel>
                </Border>

                <!-- Change Password -->
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="12"
                        Padding="24"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Change Password"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"/>
                            <TextBlock Text="Keep your account secure with a strong password."
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#F1F5F9"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Current Password"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>
                            <PasswordBox x:Name="PwdCurrent"
                                         Height="40"
                                         FontSize="14"
                                         BorderBrush="#CBD5E1"
                                         BorderThickness="1"
                                         CornerRadius="6"
                                         Padding="10,0"
                                         PlaceholderText="Enter current password"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="New Password"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>
                            <PasswordBox x:Name="PwdNew"
                                         Height="40"
                                         FontSize="14"
                                         BorderBrush="#CBD5E1"
                                         BorderThickness="1"
                                         CornerRadius="6"
                                         Padding="10,0"
                                         PlaceholderText="Enter new password"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Confirm Password"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>
                            <PasswordBox x:Name="PwdConfirm"
                                         Height="40"
                                         FontSize="14"
                                         BorderBrush="#CBD5E1"
                                         BorderThickness="1"
                                         CornerRadius="6"
                                         Padding="10,0"
                                         PlaceholderText="Confirm new password"/>
                        </StackPanel>
                        <Button Content="Update Password"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="14"
                                CornerRadius="6"
                                Click="BtnUpdatePassword_Click"/>
                    </StackPanel>
                </Border>

                <!-- Security Settings -->
                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="12"
                        Padding="24"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Security Settings"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"/>
                            <TextBlock Text="Configure security policies for your system."
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#F1F5F9"/>
                        <CheckBox Content="Require Strong Passwords"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#334155"/>
                        <CheckBox Content="Allow Receptionist Password Reset"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#334155"/>
                        <CheckBox Content="Enable Login Audit Trail"
                                  IsChecked="True"
                                  FontSize="13"
                                  Foreground="#334155"/>
                        <CheckBox Content="Auto Logout After Inactivity"
                                  FontSize="13"
                                  Foreground="#334155"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Inactivity Timeout (minutes)"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>
                            <ComboBox Height="40"
                                      HorizontalAlignment="Stretch"
                                      SelectedIndex="0"
                                      FontSize="14"
                                      BorderBrush="#CBD5E1"
                                      CornerRadius="6">
                                <ComboBoxItem Content="30 minutes"/>
                                <ComboBoxItem Content="60 minutes"/>
                                <ComboBoxItem Content="90 minutes"/>
                                <ComboBoxItem Content="120 minutes"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 2 -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Database Settings -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="12"
                        Padding="24"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Database Settings"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"/>
                            <TextBlock Text="Connection details for your Supabase instance."
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#F1F5F9"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Server"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>
                            <TextBox Text="Supabase Cloud"
                                     IsReadOnly="True"
                                     Height="40"
                                     FontSize="14"
                                     BorderBrush="#E2E8F0"
                                     BorderThickness="1"
                                     CornerRadius="6"
                                     Padding="10,0"
                                     Foreground="#94A3B8"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Database"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#475569"/>
                            <TextBox Text="SmartReceptionDB"
                                     IsReadOnly="True"
                                     Height="40"
                                     FontSize="14"
                                     BorderBrush="#E2E8F0"
                                     BorderThickness="1"
                                     CornerRadius="6"
                                     Padding="10,0"
                                     Foreground="#94A3B8"/>
                        </StackPanel>
                        <Button Content="Test Connection"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                Background="#0F172A"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="14"
                                CornerRadius="6"/>
                    </StackPanel>
                </Border>

                <!-- Backup and Restore -->
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="12"
                        Padding="24"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Backup &amp; Restore"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"/>
                            <TextBlock Text="Backup your database regularly to prevent data loss."
                                       FontSize="12"
                                       Foreground="#94A3B8"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#F1F5F9"/>
                        <Border Background="#F0FDF4"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <TextBlock Text="Last backup: Not yet configured."
                                       FontSize="12"
                                       Foreground="#166534"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <Button Content="Backup Database"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                Background="#16A34A"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="14"
                                CornerRadius="6"/>
                        <Button Content="Restore Database"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="SemiBold"
                                FontSize="14"
                                CornerRadius="6"/>
                    </StackPanel>
                </Border>

                <!-- System Information -->
                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="12"
                        Padding="24"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="2">
                            <TextBlock Text="System Information"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A"/>
                            <TextBlock Text="Details about this installation."
                                       FontSize="12"
                                       Foreground="#94A3B8"/>
                        </StackPanel>
                        <Rectangle Height="1" Fill="#F1F5F9"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="System"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#94A3B8"
                                       Margin="0,0,0,12"/>
                            <TextBlock Grid.Column="1"
                                       Text="Smart Reception"
                                       FontSize="13"
                                       Foreground="#0F172A"
                                       Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="1"
                                       Text="Version"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#94A3B8"
                                       Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="1.0.0"
                                       FontSize="13"
                                       Foreground="#0F172A"
                                       Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="2"
                                       Text="Database"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#94A3B8"
                                       Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="Supabase"
                                       FontSize="13"
                                       Foreground="#0F172A"
                                       Margin="0,0,0,12"/>
                            <TextBlock Grid.Row="3"
                                       Text="Developer"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#94A3B8"/>
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Text="Administrator"
                                       FontSize="13"
                                       Foreground="#0F172A"/>
                        </Grid>
                        <Rectangle Height="1" Fill="#F1F5F9"/>
                        <TextBlock Text="© 2025 Smart Reception. All Rights Reserved."
                                   FontSize="11"
                                   Foreground="#CBD5E1"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

                <!-- Receptionist Management -->
<Border Grid.Column="3"
        Background="White"
        CornerRadius="12"
        Padding="24"
        BorderBrush="#E2E8F0"
        BorderThickness="1">
    <StackPanel Spacing="16">
        <StackPanel Spacing="2">
            <TextBlock Text="Receptionist Management"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"/>
            <TextBlock Text="Create receptionist accounts."
                       FontSize="12"
                       Foreground="#94A3B8"/>
        </StackPanel>
        <Rectangle Height="1"
                   Fill="#F1F5F9"/>
        <TextBox x:Name="TxtReceptionFirstName"
                 PlaceholderText="First Name"
                 Height="40"/>
        <TextBox x:Name="TxtReceptionLastName"
                 PlaceholderText="Last Name"
                 Height="40"/>
        <TextBox x:Name="TxtReceptionUsername"
                 PlaceholderText="Username"
                 Height="40"/>
        <PasswordBox x:Name="PwdReceptionPassword"
                     PlaceholderText="Password"
                     Height="40"/>
        <Button Content="Add Receptionist"
                Height="40"
                Background="#16A34A"
                Foreground="White"
                Click="BtnAddReceptionist_Click"/>
    </StackPanel>
</Border>

            <!-- Bottom Nav -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12">
                <AppBarButton Icon="Back"
                              Label="Back"
                              Background="#F1F5F9"
                              Foreground="#334155"
                              CornerRadius="8"
                              x:Name="settingsbackbtn"
                              Click="settingsbackbtn_Click"/>
                <Button Content="Log Out"
                        Height="40"
                        Width="100"
                        Background="#FEE2E2"
                        Foreground="#DC2626"
                        FontWeight="SemiBold"
                        FontSize="14"
                        CornerRadius="8"
                        x:Name="logoutbtn"
                        Click="logoutbtn_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
