<Page
    x:Class="smartReception.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />

        <!-- Sidebar Button Style -->
        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR NAVIGATION -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sidebar Header -->
            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11" FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Central Administration" Foreground="#64748B" FontSize="12"/>
            </StackPanel>

            <!-- Navigation Links -->
            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#10B981"/>
                </StackPanel.Resources>
                <Button Content="🏠  Master Dashboard" Click="NavMasterDashboard_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📊  Dashboard"        Click="NavDashboard_Click"     Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📜  Access Logs"       Click="NavAccessControl_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📈  General Reports"   Click="NavReports_Click"       Style="{StaticResource ActiveSidebarButtonStyle}"/>
                <Button Content="📜  System Logs"       Click="NavLogs_Click"          Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="👥  Receptionists"     Click="NavReceptionists_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="⚙️  Settings"          Click="NavSettings_Click"      Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>

            <!-- Footer / Log Out -->
            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="🚪  Sign Out" Click="NavLogout_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#047857"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="White" Padding="32,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="System Settings" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Manage administrator accounts, configure database integration and audit policies" Foreground="#64748B" FontSize="13"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="32" Spacing="24">

                    <!-- Row 1: Admin Account + Change Password + Security -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Admin Details Card -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Administrator Account" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Update your profile name and login username" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="#E2E8F0"/>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Full Name" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <TextBox x:Name="TxtAdminFullName" PlaceholderText="Loading..." Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <TextBox x:Name="TxtAdminUsername" PlaceholderText="Loading..." Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <Button Content="Save Profile" HorizontalAlignment="Stretch" Height="40"
                                        Background="#059669" Foreground="White" FontWeight="Bold"
                                        CornerRadius="8" Click="BtnSaveAccount_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Change Password Card -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Change Password" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Update your login password regularly to maintain security" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="#E2E8F0"/>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Current Password" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <PasswordBox x:Name="PwdCurrent" PlaceholderText="••••••••" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="New Password" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <PasswordBox x:Name="PwdNew" PlaceholderText="••••••••" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Confirm New Password" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <PasswordBox x:Name="PwdConfirm" PlaceholderText="••••••••" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <Button Content="Update Password" HorizontalAlignment="Stretch" Height="40"
                                        Background="#059669" Foreground="White" FontWeight="Bold"
                                        CornerRadius="8" Click="BtnUpdatePassword_Click"/>
                            </StackPanel>
                        </Border>

                        <!-- Security Policy Card -->
                        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Security Configuration" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Define building login audit trail policies and parameters" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="#E2E8F0"/>
                                <CheckBox Content="Enforce Strong Passwords" IsChecked="True" FontSize="13" Foreground="#334155"/>
                                <CheckBox Content="Allow Front Reset Actions" IsChecked="True" FontSize="13" Foreground="#334155"/>
                                <CheckBox Content="Track Realtime Audit Trail" IsChecked="True" FontSize="13" Foreground="#334155"/>
                                <CheckBox Content="Session Inactivity Timeout" FontSize="13" Foreground="#334155"/>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Inactivity Limit" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <ComboBox Height="40" HorizontalAlignment="Stretch" SelectedIndex="0"
                                              CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black">
                                        <ComboBoxItem Content="30 minutes" Foreground="Black"/>
                                        <ComboBoxItem Content="60 minutes" Foreground="Black"/>
                                        <ComboBoxItem Content="90 minutes" Foreground="Black"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Row 2: Create Admin Account (full width) -->
                    <Border Background="White" CornerRadius="12" Padding="24"
                            BorderBrush="#E2E8F0" BorderThickness="1">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Create Admin Account" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="Add a second administrator account (maximum 2 admin accounts allowed)"
                                           FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Rectangle Height="1" Fill="#E2E8F0"/>

                            <!-- Cap warning banner (hidden by default, shown when 2 admins exist) -->
                            <Border x:Name="AdminCapBanner" Background="#FFF7ED" BorderBrush="#FED7AA"
                                    BorderThickness="1" CornerRadius="8" Padding="12"
                                    Visibility="Collapsed">
                                <TextBlock Text="⚠️  Maximum of 2 admin accounts reached. Remove an existing account to create a new one."
                                           FontSize="12" Foreground="#C2410C" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Create form (hidden when at cap) -->
                            <Grid x:Name="CreateAdminForm" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="First Name" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <TextBox x:Name="TxtNewAdminFirstName" PlaceholderText="e.g. Abaasa"
                                             Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Last Name" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <TextBox x:Name="TxtNewAdminLastName" PlaceholderText="e.g. Max"
                                             Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <TextBox x:Name="TxtNewAdminUsername" PlaceholderText="e.g. Abaasa_admin"
                                             Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="6">
                                    <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <PasswordBox x:Name="PwdNewAdmin" PlaceholderText="••••••••"
                                                 Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"/>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="BtnCreateAdmin" Content="✚  Create Admin Account"
                                    HorizontalAlignment="Left" Height="40" MinWidth="220"
                                    Background="#059669" Foreground="White" FontWeight="Bold"
                                    CornerRadius="8" Click="BtnCreateAdmin_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Row 3: Database and System Info -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Supabase Database Card -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Supabase Integration" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Active secure connection info to database servers" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="#E2E8F0"/>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="API Endpoint" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <TextBox Text="Supabase Cloud Gateway" IsReadOnly="True" Height="40" CornerRadius="8" BorderBrush="#E2E8F0" Foreground="#64748B"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="Database Namespace" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                    <TextBox Text="SmartReceptionDB" IsReadOnly="True" Height="40" CornerRadius="8" BorderBrush="#E2E8F0" Foreground="#64748B"/>
                                </StackPanel>
                                <Button Content="Test API Sync Link" HorizontalAlignment="Stretch" Height="40"
                                        Background="#1E293B" Foreground="White" FontWeight="Bold" CornerRadius="8"/>
                            </StackPanel>
                        </Border>

                        <!-- Database Backup Card -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Backup &amp; Restore" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Safeguard against database logs loss" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="#E2E8F0"/>
                                <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="8" Padding="12">
                                    <TextBlock Text="Status: All logs synchronized to live cloud servers."
                                               FontSize="12" Foreground="#047857" TextWrapping="Wrap"/>
                                </Border>
                                <Button Content="Export Cloud Backup" HorizontalAlignment="Stretch" Height="40"
                                        Background="#059669" Foreground="White" FontWeight="Bold" CornerRadius="8"/>
                                <Button Content="Import Database" HorizontalAlignment="Stretch" Height="40"
                                        Background="#1E293B" Foreground="White" FontWeight="Bold" CornerRadius="8"/>
                            </StackPanel>
                        </Border>

                        <!-- System Information Card -->
                        <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24" BorderBrush="#E2E8F0" BorderThickness="1">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="System Information" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Installed app version and host platform details" FontSize="12" Foreground="#64748B"/>
                                </StackPanel>
                                <Rectangle Height="1" Fill="#E2E8F0"/>
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="App Name" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Grid.Column="1" Text="Smart Reception" FontSize="13" Foreground="#0F172A"/>

                                    <TextBlock Grid.Row="1" Text="Version" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="1.0.0 (Build 2026)" FontSize="13" Foreground="#0F172A"/>

                                    <TextBlock Grid.Row="2" Text="Framework" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Windows UWP .NET Core" FontSize="13" Foreground="#0F172A"/>

                                    <TextBlock Grid.Row="3" Text="Database" FontSize="12" FontWeight="SemiBold" Foreground="#64748B"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Supabase C# SDK" FontSize="13" Foreground="#0F172A"/>
                                </Grid>
                                <Rectangle Height="1" Fill="#E2E8F0"/>
                                <TextBlock Text="© 2026 Cementers Plaza. All rights reserved." FontSize="11" Foreground="#94A3B8"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
