<Page
    x:Class="smartReception.entry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />
        <Style TargetType="TextBlock" x:Key="HeaderTextStyle">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Sidebar Button Style -->
        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR NAVIGATION -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sidebar Header -->
            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11" FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Central Administration" Foreground="#64748B" FontSize="12"/>
            </StackPanel>

            <!-- Navigation Links -->
            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#10B981"/>
                </StackPanel.Resources>
                <Button Content="📊  Dashboard" Click="NavDashboard_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📝  Register Clients" Click="NavRegister_Click" Style="{StaticResource ActiveSidebarButtonStyle}"/>
            </StackPanel>

            <!-- Footer / Log Out -->
            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="🚪  Sign Out" Click="NavLogout_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#047857"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="White" Padding="32,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Client Directory" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Register new clients, manage credentials and view building access periods" Foreground="#64748B" FontSize="13"/>
                </StackPanel>
            </Grid>

            <!-- Pivot Tabs -->
            <Pivot x:Name="rootPivot" Grid.Row="1" Background="Transparent" Margin="32,20,32,32" RequestedTheme="Light">
                <!-- TAB 1: REGISTRATION -->
                <PivotItem Header="Register Client">
                    <Grid Background="Transparent">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="White" CornerRadius="12" Padding="32" BorderBrush="#E2E8F0" BorderThickness="1" MaxWidth="600" Margin="0,16,0,0" Width="899">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Client Registration Form" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,8"/>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="First Name" Style="{StaticResource HeaderTextStyle}"/>
                                            <TextBox x:Name="TxtFirstName" Foreground="Black" PlaceholderText="Trevor" Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Last Name" Style="{StaticResource HeaderTextStyle}"/>
                                            <TextBox x:Name="TxtLastName" Foreground="Black" PlaceholderText="Mac" Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Email Address" Style="{StaticResource HeaderTextStyle}"/>
                                            <TextBox x:Name="TxtEmail" Foreground="Black" PlaceholderText="example@domain.com" Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Phone Number" Style="{StaticResource HeaderTextStyle}"/>
                                            <TextBox x:Name="TxtPhone" Foreground="Black" MaxLength="14" PlaceholderText="+256..." Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="NIN (National ID)" Style="{StaticResource HeaderTextStyle}"/>
                                            <TextBox x:Name="TxtNIN" Foreground="Black" MaxLength="14" PlaceholderText="CM123..." Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Floor Designation" Style="{StaticResource HeaderTextStyle}"/>
                                            <ComboBox x:Name="cmbfloor" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black">
                                                <ComboBoxItem Content="1st Floor" Foreground="Black"/>
                                                <ComboBoxItem Content="2nd Floor" Foreground="Black"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Start Date" Style="{StaticResource HeaderTextStyle}"/>
                                            <CalendarDatePicker x:Name="DpStart" Foreground="Black" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="End Date" Style="{StaticResource HeaderTextStyle}"/>
                                            <CalendarDatePicker x:Name="DpEnd" Foreground="Black" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                        </StackPanel>
                                    </Grid>

                                    <Button Content="SYNC TO SUPABASE CLOUD" Click="btnSave_Click"
                                            Background="#059669" Foreground="White"
                                            HorizontalAlignment="Stretch" Height="45"
                                            FontSize="14" FontWeight="Bold" CornerRadius="8" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </PivotItem>

                <!-- TAB 2: CLIENT DATABASE -->
                <PivotItem Header="Client Database">
                    <ListView x:Name="ClientsListView" Padding="0,16,0,0" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ClientDisplayModel">
                                <Border Background="White" Margin="0,0,0,12" Padding="20"
                                        CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="42" Height="42" Grid.Column="0" VerticalAlignment="Center">
                                            <Ellipse Fill="#ECFDF5"/>
                                            <TextBlock Text="{x:Bind Initials}" Foreground="#059669"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontWeight="Bold" FontSize="14"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{x:Bind FullName}" FontWeight="Bold" Foreground="#0F172A" FontSize="16"/>
                                            <TextBlock Text="{x:Bind Email}" Foreground="#64748B" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="FLOOR TARGET" FontSize="11" Foreground="#94A3B8" FontWeight="Bold" CharacterSpacing="50"/>
                                            <TextBlock Text="{x:Bind FloorName}" Foreground="#059669" FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="VALID UNTIL" FontSize="11" Foreground="#94A3B8" FontWeight="Bold" CharacterSpacing="50"/>
                                            <TextBlock Text="{x:Bind DateRange}" Foreground="#334155" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Content="Edit" Click="btnEdit_Click" CommandParameter="{x:Bind ClientID}"
                                                    Foreground="#0066E2" Background="Transparent" FontWeight="SemiBold" FontSize="13"/>
                                            <Button Content="Delete" Click="btnDelete_Click" CommandParameter="{x:Bind ClientID}"
                                                    Foreground="#DC2626" Background="Transparent" FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>
            </Pivot>
        </Grid>
    </Grid>
</Page>
