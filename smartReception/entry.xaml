<Page
    x:Class="smartReception.entry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />

        <Style TargetType="TextBlock" x:Key="FieldLabelStyle">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Sidebar Button Style -->
        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>

        <!-- Toggle button styles -->
        <Style TargetType="Button" x:Key="ToggleActiveStyle">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="Button" x:Key="ToggleInactiveStyle">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11" FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Reception Desk" Foreground="#64748B" FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#10B981"/>
                </StackPanel.Resources>
                <Button Content="📊  Dashboard" Click="NavDashboard_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📝  Register Clients" Click="NavRegister_Click" Style="{StaticResource ActiveSidebarButtonStyle}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="🚪  Sign Out" Click="NavLogout_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#047857"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="White" Padding="32,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Client &amp; Visitor Registry" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Register clients and visitors, manage access and view building directory" Foreground="#64748B" FontSize="13"/>
                </StackPanel>
            </Grid>

            <!-- Body -->
            <Pivot x:Name="rootPivot" Grid.Row="1" Background="Transparent" Margin="32,20,32,32" RequestedTheme="Light">

                <!-- ═══════════════ TAB 1: REGISTER ═══════════════ -->
                <PivotItem Header="Register">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16,0,0">
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="340"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: FORM -->
                            <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="32"
                                    BorderBrush="#E2E8F0" BorderThickness="1" VerticalAlignment="Top">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Spacing="20">

                                    <!-- Type Toggle -->
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="REGISTRATION TYPE" FontSize="11" FontWeight="Bold"
                                                   Foreground="#94A3B8" CharacterSpacing="80"/>
                                        <Border Background="#F8FAFC" CornerRadius="10" Padding="6"
                                                BorderBrush="#E2E8F0" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Button x:Name="BtnTypeClient"
                                                        Content="🏢  Client (Long-term)"
                                                        Style="{StaticResource ToggleActiveStyle}"
                                                        Click="BtnTypeClient_Click"/>
                                                <Button x:Name="BtnTypeVisitor"
                                                        Content="🪪  Visitor (Day pass)"
                                                        Style="{StaticResource ToggleInactiveStyle}"
                                                        Click="BtnTypeVisitor_Click"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- Type description -->
                                        <Border x:Name="TypeDescBorder" Background="#ECFDF5" CornerRadius="8"
                                                Padding="12,8" BorderBrush="#A7F3D0" BorderThickness="1">
                                            <TextBlock x:Name="TxtTypeDesc"
                                                       Text="🏢  Client — rents space on Floor 1 or 2. Assigned for days, months or years."
                                                       FontSize="12" Foreground="#065F46" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>

                                    <Rectangle Height="1" Fill="#E2E8F0"/>

                                    <!-- Name Row -->
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="First Name *" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="TxtFirstName" Foreground="Black"
                                                     PlaceholderText="e.g. Trevor"
                                                     Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Last Name" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="TxtLastName" Foreground="Black"
                                                     PlaceholderText="e.g. Mackenzie"
                                                     Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Email + Phone -->
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Email Address" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="TxtEmail" Foreground="Black"
                                                     PlaceholderText="example@domain.com"
                                                     Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Phone Number *" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="TxtPhone" Foreground="Black" MaxLength="14"
                                                     PlaceholderText="+256..."
                                                     Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- NIN + Floor -->
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock x:Name="TxtNINLabel" Text="NIN (National ID) *" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="TxtNIN" Foreground="Black" MaxLength="14"
                                                     PlaceholderText="CM123..."
                                                     Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Floor Designation *" Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="cmbfloor" HorizontalAlignment="Stretch" Height="40"
                                                      CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black"
                                                      SelectionChanged="FormField_Changed">
                                                <ComboBoxItem Content="1st Floor" Foreground="Black" Tag="1"/>
                                                <ComboBoxItem Content="2nd Floor" Foreground="Black" Tag="2"/>
                                                <ComboBoxItem x:Name="Floor3Item" Content="3rd Floor" Foreground="Black" Tag="3"/>
                                                <ComboBoxItem x:Name="Floor4Item" Content="4th Floor" Foreground="Black" Tag="4"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Date / Time row — switches based on type -->
                                    <!-- CLIENT: Start + End Date -->
                                    <Grid x:Name="ClientDateRow" ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Start Date *" Style="{StaticResource FieldLabelStyle}"/>
                                            <CalendarDatePicker x:Name="DpStart" Foreground="Black"
                                                                HorizontalAlignment="Stretch" Height="40"
                                                                CornerRadius="8" BorderBrush="#CBD5E1"
                                                                DateChanged="FormField_Changed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="End Date" Style="{StaticResource FieldLabelStyle}"/>
                                            <CalendarDatePicker x:Name="DpEnd" Foreground="Black"
                                                                HorizontalAlignment="Stretch" Height="40"
                                                                CornerRadius="8" BorderBrush="#CBD5E1"
                                                                DateChanged="FormField_Changed"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- VISITOR: Time In + Time Out -->
                                    <Grid x:Name="VisitorTimeRow" ColumnSpacing="16" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Time In *" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="TxtTimeIn" Foreground="Black"
                                                     PlaceholderText="HH:MM  (e.g. 09:30)"
                                                     Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Time Out (optional)" Style="{StaticResource FieldLabelStyle}"/>
                                            <TextBox x:Name="TxtTimeOut" Foreground="Black"
                                                     PlaceholderText="HH:MM  (e.g. 17:00)"
                                                     Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                                                     TextChanged="FormField_Changed"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Submit -->
                                    <Button x:Name="BtnSubmit"
                                            Content="✦  SYNC TO CLOUD"
                                            Click="btnSave_Click"
                                            Background="#059669" Foreground="White"
                                            HorizontalAlignment="Stretch" Height="48"
                                            FontSize="14" FontWeight="Bold" CornerRadius="10"
                                            Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- RIGHT: LIVE ACCESS PASS CARD -->
                            <StackPanel Grid.Column="1" Spacing="16" VerticalAlignment="Top">

                                <TextBlock Text="LIVE PREVIEW" FontSize="11" FontWeight="Bold"
                                           Foreground="#94A3B8" CharacterSpacing="80" Margin="4,0,0,0"/>

                                <!-- ACCESS PASS CARD -->
                                <Border x:Name="AccessPassCard" CornerRadius="20" Padding="0"
                                        BorderThickness="0" Height="480">
                                    <Border.Shadow>
                                        <ThemeShadow />
                                    </Border.Shadow>
                                    <Border CornerRadius="20">
                                        <Grid>

                                            <!-- Card background gradient — CLIENT green -->
                                            <Border x:Name="CardBgClient" CornerRadius="20">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#064E3B" Offset="0.0"/>
                                                        <GradientStop Color="#065F46" Offset="0.5"/>
                                                        <GradientStop Color="#047857" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <!-- Card background gradient — VISITOR blue (hidden by default) -->
                                            <Border x:Name="CardBgVisitor" CornerRadius="20" Visibility="Collapsed">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#0F172A" Offset="0.0"/>
                                                        <GradientStop Color="#1E3A5F" Offset="0.5"/>
                                                        <GradientStop Color="#1D4ED8" Offset="1.0"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <!-- Decorative circles -->
                                            <Ellipse Width="260" Height="260" Opacity="0.06"
                                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                                 Margin="0,-80,-80,0" Fill="White"/>
                                            <Ellipse Width="180" Height="180" Opacity="0.05"
                                                 HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                 Margin="-60,0,0,-60" Fill="White"/>

                                            <!-- Card Content -->
                                            <StackPanel Margin="28" Spacing="0" VerticalAlignment="Stretch">

                                                <!-- Top: org name + type badge -->
                                                <Grid Margin="0,0,0,20">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="CEMENTERS PLAZA" FontSize="10"
                                                               FontWeight="Bold" Foreground="#A7F3D0"
                                                               CharacterSpacing="120"/>
                                                        <TextBlock Text="Access Pass" FontSize="13"
                                                               Foreground="#D1FAE5" Opacity="0.8"/>
                                                    </StackPanel>
                                                    <Border x:Name="TypeBadge" Grid.Column="1"
                                                        Background="#10B981" CornerRadius="20"
                                                        Padding="12,6" VerticalAlignment="Center">
                                                        <TextBlock x:Name="TxtTypeBadge" Text="CLIENT"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="White" CharacterSpacing="60"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Avatar circle -->
                                                <Border HorizontalAlignment="Left" Margin="0,0,0,18">
                                                    <Grid Width="72" Height="72">
                                                        <Ellipse Fill="#FFFFFF" Opacity="0.12"/>
                                                        <Ellipse Width="68" Height="68" Stroke="#10B981"
                                                             StrokeThickness="2" Fill="Transparent"/>
                                                        <TextBlock x:Name="CardInitials" Text="?"
                                                               FontSize="26" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Name -->
                                                <TextBlock x:Name="CardFullName"
                                                       Text="Full Name"
                                                       FontSize="22" FontWeight="Bold"
                                                       Foreground="White" TextWrapping="Wrap"
                                                       Margin="0,0,0,4"/>
                                                <TextBlock x:Name="CardEmail"
                                                       Text="email@domain.com"
                                                       FontSize="13" Foreground="#A7F3D0"
                                                       Opacity="0.85" Margin="0,0,0,20"
                                                       TextWrapping="Wrap"/>

                                                <!-- Divider -->
                                                <Rectangle Height="1" Fill="#FFFFFF" Opacity="0.12" Margin="0,0,0,20"/>

                                                <!-- Detail grid -->
                                                <Grid RowSpacing="14">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Phone -->
                                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                                        <TextBlock Text="PHONE" FontSize="9" FontWeight="Bold"
                                                               Foreground="#6EE7B7" CharacterSpacing="80"/>
                                                        <TextBlock x:Name="CardPhone" Text="—"
                                                               FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                                                    </StackPanel>

                                                    <!-- Floor -->
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                                                        <TextBlock Text="FLOOR" FontSize="9" FontWeight="Bold"
                                                               Foreground="#6EE7B7" CharacterSpacing="80"/>
                                                        <TextBlock x:Name="CardFloor" Text="—"
                                                               FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                                                    </StackPanel>

                                                    <!-- Date / Time label row -->
                                                    <StackPanel x:Name="CardDateRow" Grid.Row="1" Grid.Column="0"
                                                            Grid.ColumnSpan="2" Spacing="2">
                                                        <TextBlock x:Name="CardDateLabel" Text="ACCESS PERIOD"
                                                               FontSize="9" FontWeight="Bold"
                                                               Foreground="#6EE7B7" CharacterSpacing="80"/>
                                                        <TextBlock x:Name="CardDateValue" Text="—"
                                                               FontSize="13" Foreground="White" FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <!-- NIN -->
                                                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2">
                                                        <TextBlock Text="NIN" FontSize="9" FontWeight="Bold"
                                                               Foreground="#6EE7B7" CharacterSpacing="80"/>
                                                        <TextBlock x:Name="CardNIN" Text="—"
                                                               FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Bottom strip -->
                                                <Border Margin="0,20,0,0" Background="#FFFFFF" Opacity="0.08"
                                                    CornerRadius="8" Padding="12,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Smart Reception System"
                                                               FontSize="11" Foreground="White" Opacity="0.7"
                                                               VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="2026"
                                                               FontSize="11" Foreground="White" Opacity="0.5"
                                                               VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Border>

                                <!-- Hint text -->
                                <TextBlock Text="Preview updates as you fill in the form above."
                                           FontSize="11" Foreground="#94A3B8" TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </PivotItem>

                <!-- ═══════════════ TAB 2: CLIENT DATABASE ═══════════════ -->
                <PivotItem Header="Client Database">
                    <ListView x:Name="ClientsListView" Padding="0,16,0,0" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ClientDisplayModel">
                                <Border Background="White" Margin="0,0,0,12" Padding="20"
                                        CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="42" Height="42" VerticalAlignment="Center">
                                            <Ellipse Fill="#ECFDF5"/>
                                            <TextBlock Text="{x:Bind Initials}" Foreground="#059669"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontWeight="Bold" FontSize="14"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{x:Bind FullName}" FontWeight="Bold" Foreground="#0F172A" FontSize="15"/>
                                            <TextBlock Text="{x:Bind Email}" Foreground="#64748B" FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="FLOOR" FontSize="10" Foreground="#94A3B8" FontWeight="Bold" CharacterSpacing="50"/>
                                            <TextBlock Text="{x:Bind FloorName}" Foreground="#059669" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="VALID UNTIL" FontSize="10" Foreground="#94A3B8" FontWeight="Bold" CharacterSpacing="50"/>
                                            <TextBlock Text="{x:Bind DateRange}" Foreground="#334155" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Content="Edit" Click="btnEdit_Click"
                                                    CommandParameter="{x:Bind ClientID}"
                                                    Foreground="#0066E2" Background="Transparent"
                                                    FontWeight="SemiBold" FontSize="13"/>
                                            <Button Content="Delete" Click="btnDelete_Click"
                                                    CommandParameter="{x:Bind ClientID}"
                                                    Foreground="#DC2626" Background="Transparent"
                                                    FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>

                <!-- ═══════════════ TAB 3: VISITOR DATABASE ═══════════════ -->
                <PivotItem Header="Visitor Log">
                    <ListView x:Name="VisitorsListView" Padding="0,16,0,0" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:VisitorDisplayModel">
                                <Border Background="White" Margin="0,0,0,12" Padding="20"
                                        CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="1.2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="42" Height="42" VerticalAlignment="Center">
                                            <Ellipse Fill="#EFF6FF"/>
                                            <TextBlock Text="{x:Bind Initials}" Foreground="#1D4ED8"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontWeight="Bold" FontSize="14"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind FullName}" FontWeight="Bold" Foreground="#0F172A" FontSize="15"/>
                                                <Border Background="#EFF6FF" CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="VISITOR" FontSize="10" FontWeight="Bold"
                                                               Foreground="#1D4ED8" CharacterSpacing="40"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Email}" Foreground="#64748B" FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="FLOOR" FontSize="10" Foreground="#94A3B8" FontWeight="Bold" CharacterSpacing="50"/>
                                            <TextBlock Text="{x:Bind FloorName}" Foreground="#1D4ED8" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="VISIT TIME" FontSize="10" Foreground="#94A3B8" FontWeight="Bold" CharacterSpacing="50"/>
                                            <TextBlock Text="{x:Bind TimeRange}" Foreground="#334155" FontSize="13"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Button Content="Delete" Click="btnDeleteVisitor_Click"
                                                    CommandParameter="{x:Bind VisitorID}"
                                                    Foreground="#DC2626" Background="Transparent"
                                                    FontWeight="SemiBold" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </PivotItem>

            </Pivot>
        </Grid>
    </Grid>
</Page>
