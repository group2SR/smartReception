<Page
    x:Class="smartReception.entry"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F3F4F6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="DarkGreen" Padding="30,20">
            <StackPanel>
                <TextBlock Text="SMART RECEPTION" FontSize="28" FontWeight="Bold" Foreground="White" CharacterSpacing="100"/>
                <TextBlock Text="Visitor Management &amp; Cloud Sync System" Foreground="#E0E0E0" FontWeight="Light"/>
            </StackPanel>
        </Border>

        <Pivot Grid.Row="1" Padding="10">
            <Pivot.Resources>
                <Style TargetType="PivotHeaderItem">
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </Pivot.Resources>

            <PivotItem Header="REGISTRATION">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>

                    <!-- Form Section -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,20,0">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Client Information" FontSize="20" FontWeight="SemiBold" Foreground="Black"/>

                            <Border Background="White" CornerRadius="12" Padding="25" BorderBrush="#CCCCCC" BorderThickness="1">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtfirstname" Header="First Name" Foreground="Black" Text="{Binding FirstName, Mode=TwoWay}" PlaceholderText="eg. Stuart" Margin="0,0,10,0"/>
                                        <TextBox x:Name="txtlastname" Grid.Column="1" Header="Last Name" Foreground="Black" Text="{Binding LastName, Mode=TwoWay}" PlaceholderText="eg. Mukalazi"/>
                                    </Grid>

                                    <TextBox x:Name="txtemail" Header="Email Address" Foreground="Black" Text="{Binding Email, Mode=TwoWay}" PlaceholderText="stumuk@gmail.com"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtphonenumber" Header="Phone" Foreground="Black" Text="{Binding PhoneNumber, Mode=TwoWay}" PlaceholderText="+256..." Margin="0,0,10,0"/>
                                        <TextBox x:Name="txtnin" Grid.Column="1" Header="NIN / ID" Foreground="Black" Text="{Binding NIN, Mode=TwoWay}" PlaceholderText="CM373..."/>
                                    </Grid>
                                    <!-- Fixed property names to match ViewModel exactly -->
                                    <ComboBox x:Name="cmbfloor" Header="Floor Designation" Foreground="Black" 
          SelectedValue="{Binding FloorID, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="1st Floor" Foreground="Black"/>
                                        <ComboBoxItem Content="2nd Floor" Foreground="Black"/>
                                    </ComboBox>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CalendarDatePicker x:Name="startdate" Header="Start Date" Foreground="Black" 
                        Date="{Binding StartDate, Mode=TwoWay}" HorizontalAlignment="Stretch" Margin="0,0,10,0"/>
                                        <CalendarDatePicker x:Name="endDate" Grid.Column="1" Header="End Date" Foreground="Black" 
                        Date="{Binding EndDate, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                                    </Grid>

                                    <Button Content="SYNC TO CLOUD" Click="btnSave" Background="DarkGreen" Foreground="White" FontWeight="Bold" Padding="30,12" HorizontalAlignment="Right" CornerRadius="6" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Identity Preview -->
                    <StackPanel Grid.Column="1" Spacing="15">
                        <TextBlock Text="Identity Preview" FontSize="20" FontWeight="SemiBold" Foreground="Black"/>
                        <Border Background="White" CornerRadius="12" Padding="30" BorderBrush="DarkGreen" BorderThickness="0,5,0,0">
                            <StackPanel Spacing="20" HorizontalAlignment="Center">
                                <Grid Width="100" Height="100">
                                    <Ellipse Fill="#E8F5E9"/>
                                    <TextBlock Text="{Binding Initials}" FontSize="36" FontWeight="Bold" Foreground="DarkGreen" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>

                                <StackPanel Spacing="5" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding FullName, FallbackValue='Visitor Name'}" FontSize="22" FontWeight="Bold" Foreground="Black" TextAlignment="Center"/>
                                    <TextBlock Text="{Binding NIN, FallbackValue='ID: ---'}" Foreground="#333333" TextAlignment="Center"/>
                                </StackPanel>

                                <Border Background="#F9F9F9" Padding="15" CornerRadius="8">
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="{Binding Email}" Foreground="Black" FontSize="13" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding PhoneNumber}" Foreground="Black" FontSize="13" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </PivotItem>

            <PivotItem Header="CLIENT DATABASE">
                <ListView ItemsSource="{x:Bind Clients}" Padding="10" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ClientDisplayModel">
                            <Border Background="White" Margin="0,0,0,12" Padding="20" CornerRadius="10" BorderBrush="#DDDDDD" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid VerticalAlignment="Center" Margin="0,0,20,0">
                                        <Ellipse Fill="DarkGreen" Width="50" Height="50"/>
                                        <TextBlock Text="{x:Bind Initials}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="{x:Bind FullName}" FontSize="18" FontWeight="Bold" Foreground="Black"/>
                                            <Border Background="#E3F2FD" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{x:Bind FloorID}" FontSize="10" Foreground="#0D47A1" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Email}" Foreground="Black" FontSize="14"/>
                                        <TextBlock Text="{x:Bind DateRange}" FontSize="12" Foreground="#444444" FontStyle="Italic"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <Button Content="Edit" BorderBrush="DarkGreen" BorderThickness="1" Foreground="DarkGreen" Width="80" CornerRadius="4"/>
                                        <Button Content="Delete" BorderBrush="DarkRed" BorderThickness="1" Foreground="DarkRed" Width="80" CornerRadius="4"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>