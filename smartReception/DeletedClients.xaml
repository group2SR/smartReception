<Page
    x:Class="smartReception.DeletedClients"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F8FAFC">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Padding="24" HorizontalAlignment="Stretch">

            <TextBlock Text="Deleted Clients" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#0F172A" 
                       Margin="0,0,0,20"/>

            <Border Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E2E8F0" 
                    BorderThickness="1" 
                    Padding="24">

                <StackPanel>

                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Filter Deleted Clients" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#0F172A" 
                                   VerticalAlignment="Center"/>

                        <Button HorizontalAlignment="Right" 
                                Background="Transparent" 
                                BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="6" 
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE8B6;" FontSize="14" Foreground="#1E293B" Margin="0,0,8,0"/>
                                <TextBlock Text="Generate Report" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Search Client" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <TextBox PlaceholderText="Search by name or NIN..." Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Date From" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <CalendarDatePicker PlaceholderText="01/05/2025" HorizontalAlignment="Stretch" Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="Date To" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <CalendarDatePicker PlaceholderText="31/05/2025" HorizontalAlignment="Stretch" Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,16,0">
                            <TextBlock Text="Floor" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <ComboBox PlaceholderText="All Floors" HorizontalAlignment="Stretch" Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <Button Grid.Column="4" 
                                VerticalAlignment="Bottom" 
                                Height="38" 
                                Width="120"
                                Background="#0066E2" 
                                Foreground="White" 
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE71E;" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                        <StackPanel>

                            <Grid Background="#F1F5F9" Padding="12,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.8*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Deleted ID" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="1" Text="Client ID" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="2" Text="Full Name" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="3" Text="NIN" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="4" Text="Floor" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="5" Text="Start Date" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="6" Text="End Date" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="7" Text="Deleted By" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="8" Text="Deleted Date" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="9" Text="Reason" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                            </Grid>

                            <ListView SelectionMode="None" IsItemClickEnabled="False" Padding="0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="MinHeight" Value="48"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="12,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="1.8*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="1010" FontSize="13" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="1006" FontSize="13" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="John Mwangi" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="12345678" FontSize="13" Foreground="#334155" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="1st Floor" FontSize="13" Foreground="#334155" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="01/01/2025" FontSize="13" Foreground="#334155" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="31/12/2025" FontSize="13" Foreground="#334155" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="7" Text="Administrator" FontSize="13" Foreground="#334155" VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="8" VerticalAlignment="Center">
                                                <TextBlock Text="31/05/2025" FontSize="13" Foreground="#334155" FontWeight="Medium"/>
                                                <TextBlock Text="09:15 AM" FontSize="11" Foreground="#64748B"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="9" Text="Moved Out" FontSize="13" Foreground="#334155" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,16,0,0">
                        <TextBlock Text="Showing 1 to 5 of 0 entries" 
                                   FontSize="13" 
                                   Foreground="#475569" 
                                   VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                            <Button Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
                                <FontIcon Glyph="&#xE76B;" FontSize="10"/>
                            </Button>

                            <Button Content="1" Width="32" Height="32" Padding="0" Background="#0066E2" Foreground="White" FontWeight="Bold" CornerRadius="4"/>
                            <Button Content="2" Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"/>
                            <Button Content="3" Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"/>
                            <Button Content="4" Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"/>
                            <Button Content="5" Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"/>

                            <Button Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
                                <FontIcon Glyph="&#xE76C;" FontSize="10"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>