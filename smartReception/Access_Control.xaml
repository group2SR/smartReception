<Page
    x:Class="smartReception.Access_Control"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F8FAFC">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Padding="24" HorizontalAlignment="Stretch">

            <TextBlock Text="Access Logs" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="#0F172A" 
                       Margin="0,0,0,20"/>

            <Border Background="White" 
                    CornerRadius="8" 
                    BorderBrush="#E2E8F0" 
                    BorderThickness="1" 
                    Padding="24">

                <StackPanel>

                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Filter Access Logs" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#0F172A" 
                                   VerticalAlignment="Center"/>

                        <Button HorizontalAlignment="Right" 
                                Background="Transparent" 
                                BorderBrush="#CBD5E1" 
                                BorderThickness="1" 
                                CornerRadius="6" 
                                Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE8B6;" FontSize="14" Foreground="#1E293B" Margin="0,0,8,0"/>
                                <TextBlock Text="Export Logs" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Search Client" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <TextBox PlaceholderText="Search by name or NIN..." Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Floor" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <ComboBox PlaceholderText="All Floors" HorizontalAlignment="Stretch" Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="Date From" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <CalendarDatePicker PlaceholderText="01/05/2025" HorizontalAlignment="Stretch" Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,16,0">
                            <TextBlock Text="Date To" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <CalendarDatePicker PlaceholderText="31/05/2025" HorizontalAlignment="Stretch" Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <Button Grid.Column="4" 
                                VerticalAlignment="Bottom" 
                                Height="38" 
                                Width="120"
                                Background="#0066E2" 
                                Foreground="White" 
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE71E;" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <MenuFlyoutSeparator Background="#E2E8F0" Margin="0,0,0,12"/>

                    <ListView SelectionMode="None" IsItemClickEnabled="True">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <Ellipse Width="44" Height="44" Fill="#10B981"/>
                                        <TextBlock Text="JM" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="John Mwangi" FontSize="15" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="NIN: " FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="12345678" FontSize="12" Foreground="#334155" FontWeight="Medium"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Floor: " FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="1st Floor" FontSize="12" Foreground="#334155" FontWeight="Medium"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <FontIcon Glyph="&#xE787;" FontSize="14" Foreground="#6366F1" Margin="0,0,6,0"/>
                                            <TextBlock Text="31/05/2025" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        </StackPanel>
                                        <TextBlock Text="Date" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <FontIcon Glyph="&#xE72A;" FontSize="14" Foreground="#10B981" Margin="0,0,6,0"/>
                                            <TextBlock Text="08:01 AM" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        </StackPanel>
                                        <TextBlock Text="Time In" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#EF4444" Margin="0,0,6,0"/>
                                            <TextBlock Text="05:02 PM" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        </StackPanel>
                                        <TextBlock Text="Time Out" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="5" VerticalAlignment="Center" Spacing="6" HorizontalAlignment="Right">
                                        <Border Background="#E6F4EA" CornerRadius="12" Padding="12,4" HorizontalAlignment="Center">
                                            <TextBlock Text="Completed" FontSize="11" FontWeight="SemiBold" Foreground="#137333"/>
                                        </Border>
                                        <Button Content="View Details" 
                                                Background="Transparent" 
                                                BorderBrush="#CBD5E1" 
                                                BorderThickness="1" 
                                                CornerRadius="4" 
                                                Padding="10,4"
                                                FontSize="12" 
                                                FontWeight="SemiBold"
                                                Foreground="#0066E2"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Margin="0,16,0,0">
                        <TextBlock Text="Showing 1 to 5 of 0 entries" 
                                   FontSize="13" 
                                   Foreground="#475569" 
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                <Button Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
                                    <FontIcon Glyph="&#xE76B;" FontSize="10"/>
                                </Button>

                                <Button Content="1" Width="32" Height="32" Padding="0" Background="#0066E2" Foreground="White" FontWeight="Bold" CornerRadius="4"/>
                                <Button Content="2" Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"/>
                                <Button Content="3" Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"/>
                                <Button Content="4" Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"/>
                                <Button Content="5" Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4"/>

                                <Button Width="32" Height="32" Padding="0" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="4">
                                    <FontIcon Glyph="&#xE76C;" FontSize="10"/>
                                </Button>
                            </StackPanel>
                          
                        </StackPanel>
                    </Grid>
                   

                </StackPanel>
            </Border>
            <StackPanel>
                <Button Content="log out" Background="PaleVioletRed" Foreground="White" CornerRadius="10" x:Name="receptionistlogoutbtn" HorizontalAlignment="Right" Margin="0,10,0,0" Click="receptionistlogoutbtn_Click"/>
                <AppBarButton Icon="Back" Label="back" HorizontalAlignment="Right" x:Name="receptionaccesbackbtn" Click="receptionaccesbackbtn_Click" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>