<Page
    x:Class="smartReception.Access_Control"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F8FAFC">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Padding="24" HorizontalAlignment="Stretch">

            <TextBlock Text="Access Logs"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#0F172A" Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="8"
                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
                <StackPanel>

                    <!-- Header row -->
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Filter Access Logs"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#0F172A" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right"
                                Background="Transparent" BorderBrush="#CBD5E1"
                                BorderThickness="1" CornerRadius="6" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE8B6;" FontSize="14" Foreground="#1E293B" Margin="0,0,8,0"/>
                                <TextBlock Text="Export Logs" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Filter row -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Search Client" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <TextBox x:Name="SearchBox"
                                     PlaceholderText="Search by name or NIN..."
                                     Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="Floor" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <ComboBox x:Name="FloorCombo"
                                      PlaceholderText="All Floors"
                                      HorizontalAlignment="Stretch" Height="38"
                                      CornerRadius="6" BorderBrush="#CBD5E1">
                                <ComboBoxItem Content="All Floors" IsSelected="True"/>
                                <ComboBoxItem Content="1st Floor"/>
                                <ComboBoxItem Content="2nd Floor"/>
                                <ComboBoxItem Content="3rd Floor"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="Date From" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <CalendarDatePicker x:Name="DateFrom"
                                                PlaceholderText="dd/mm/yyyy"
                                                HorizontalAlignment="Stretch"
                                                Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,16,0">
                            <TextBlock Text="Date To" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                            <CalendarDatePicker x:Name="DateTo"
                                                PlaceholderText="dd/mm/yyyy"
                                                HorizontalAlignment="Stretch"
                                                Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <Button Grid.Column="4"
                                VerticalAlignment="Bottom" Height="38" Width="120"
                                Background="#0066E2" Foreground="White" CornerRadius="6"
                                Click="SearchButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE71E;" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <MenuFlyoutSeparator Background="#E2E8F0" Margin="0,0,0,12"/>

                    <!-- Loading indicator -->
                    <ProgressRing x:Name="LoadingRing"
                                  IsActive="False" Visibility="Collapsed"
                                  Width="40" Height="40"
                                  Foreground="#0066E2"
                                  HorizontalAlignment="Center" Margin="0,20,0,20"/>

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                                HorizontalAlignment="Center" Margin="0,40,0,40">
                        <FontIcon Glyph="&#xE838;" FontSize="48" Foreground="#CBD5E1"/>
                        <TextBlock Text="No access logs found"
                                   FontSize="16" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" Margin="0,12,0,4"/>
                        <TextBlock Text="Try adjusting your filters"
                                   FontSize="13" Foreground="#CBD5E1"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Data list -->
                    <ListView x:Name="AccessLogsList"
                              SelectionMode="None" IsItemClickEnabled="True">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,12"/>
                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <!-- NO x:DataType — plain {Binding} works with C# 7.3 -->
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar -->
                                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <Ellipse Width="44" Height="44" Fill="#10B981"/>
                                        <TextBlock Text="{Binding Initials}"
                                                   Foreground="White" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Name / NIN / Floor -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ClientName}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="#0F172A" Margin="0,0,0,4"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="NIN: " FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding NIN}" FontSize="12" Foreground="#334155" FontWeight="Medium"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Floor: " FontSize="12" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding Floor}" FontSize="12" Foreground="#334155" FontWeight="Medium"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Date -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <FontIcon Glyph="&#xE787;" FontSize="14" Foreground="#6366F1" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Date}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        </StackPanel>
                                        <TextBlock Text="Date" FontSize="11" Foreground="#94A3B8"/>
                                    </StackPanel>

                                    <!-- Time In -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <FontIcon Glyph="&#xE72A;" FontSize="14" Foreground="#10B981" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding TimeIn}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        </StackPanel>
                                        <TextBlock Text="Time In" FontSize="11" Foreground="#94A3B8"/>
                                    </StackPanel>

                                    <!-- Time Out -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#EF4444" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding TimeOut}" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                        </StackPanel>
                                        <TextBlock Text="Time Out" FontSize="11" Foreground="#94A3B8"/>
                                    </StackPanel>

                                    <!-- Status + button -->
                                    <StackPanel Grid.Column="5" VerticalAlignment="Center"
                                                Spacing="6" HorizontalAlignment="Right">
                                        <Border Background="#E6F4EA" CornerRadius="12"
                                                Padding="12,4" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="11" FontWeight="SemiBold" Foreground="#137333"/>
                                        </Border>
                                        <Button Content="View Details"
                                                Background="Transparent"
                                                BorderBrush="#CBD5E1" BorderThickness="1"
                                                CornerRadius="4" Padding="10,4"
                                                FontSize="12" FontWeight="SemiBold"
                                                Foreground="#0066E2"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Footer: entries label + pagination -->
                    <Grid Margin="0,16,0,0">
                        <TextBlock x:Name="EntriesLabel"
                                   Text="Showing 0 to 0 of 0 entries"
                                   FontSize="13" Foreground="#475569"
                                   VerticalAlignment="Center"/>
                        <StackPanel x:Name="PaginationPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right" Spacing="4"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Logout / Back -->
            <StackPanel>
                <Button Content="Log Out"
                        Background="PaleVioletRed" Foreground="White"
                        CornerRadius="10" x:Name="receptionistlogoutbtn"
                        HorizontalAlignment="Right" Margin="0,10,0,0"
                        Click="receptionistlogoutbtn_Click"/>
                <AppBarButton Icon="Back" Label="back"
                              HorizontalAlignment="Right"
                              x:Name="receptionaccesbackbtn"
                              Click="receptionaccesbackbtn_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>