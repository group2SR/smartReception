<Page
    x:Class="smartReception.Access_Control"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />

        <Style TargetType="TextBlock" x:Key="HeaderTextStyle">
            <Setter Property="Foreground"  Value="#475569"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>

        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment"        Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="24,0,0,0"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="CornerRadius"    Value="8"/>
        </Style>

        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle"
               BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11"
                           FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Desk Receptionist" Foreground="#64748B" FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="#10B981"/>
                </StackPanel.Resources>
                <Button Content="📊  Dashboard"      Click="NavDashboard_Click"     Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📜  Access Logs"     Click="NavAccessControl_Click" Style="{StaticResource ActiveSidebarButtonStyle}"/>
                <Button Content="📈  General Reports" Click="NavReports_Click"       Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="📜  System Logs"     Click="NavLogs_Click"          Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="👥  Receptionists"   Click="NavReceptionists_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="⚙️  Settings"        Click="NavSettings_Click"      Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="🚪  Sign Out" Click="NavLogout_Click"
                        Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#047857"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="White"/>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="White" Padding="32,20"
                  BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Access Logs" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="View and filter building entry and exit history for clients and visitors"
                               Foreground="#64748B" FontSize="13"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" Padding="32" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="24">
                    <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0"
                            BorderThickness="1" Padding="28">
                        <StackPanel>

                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Filter Access Logs" FontSize="18"
                                           FontWeight="Bold" Foreground="#0F172A"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Filters -->
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Search" Style="{StaticResource HeaderTextStyle}"/>
                                    <TextBox x:Name="SearchBox" Foreground="Black"
                                             PlaceholderText="Search by name or NIN..."
                                             Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                </StackPanel>

                                <!-- Floor combo — all 4 floors -->
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Floor" Style="{StaticResource HeaderTextStyle}"/>
                                    <ComboBox x:Name="FloorCombo" HorizontalAlignment="Stretch"
                                              Height="40" CornerRadius="8" BorderBrush="#CBD5E1"
                                              Foreground="Black">
                                        <ComboBoxItem Content="All Floors" IsSelected="True" Foreground="Black"/>
                                        <ComboBoxItem Content="1st Floor"  Foreground="Black"/>
                                        <ComboBoxItem Content="2nd Floor"  Foreground="Black"/>
                                        <ComboBoxItem Content="3rd Floor"  Foreground="Black"/>
                                        <ComboBoxItem Content="4th Floor"  Foreground="Black"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Text="Date From" Style="{StaticResource HeaderTextStyle}"/>
                                    <CalendarDatePicker x:Name="DateFrom" Foreground="Black"
                                                        PlaceholderText="dd/mm/yyyy"
                                                        HorizontalAlignment="Stretch"
                                                        Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,16,0">
                                    <TextBlock Text="Date To" Style="{StaticResource HeaderTextStyle}"/>
                                    <CalendarDatePicker x:Name="DateTo" Foreground="Black"
                                                        PlaceholderText="dd/mm/yyyy"
                                                        HorizontalAlignment="Stretch"
                                                        Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                </StackPanel>

                                <Button Grid.Column="4" VerticalAlignment="Bottom"
                                        Height="40" Width="120" Background="#10B981"
                                        Foreground="White" CornerRadius="8"
                                        Click="SearchButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE71E;" FontSize="14"
                                                  Foreground="White" Margin="0,0,8,0"/>
                                        <TextBlock Text="Search" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <MenuFlyoutSeparator Background="#E2E8F0" Margin="0,0,0,16"/>

                            <!-- Loading -->
                            <ProgressRing x:Name="LoadingRing" IsActive="False"
                                          Visibility="Collapsed" Width="40" Height="40"
                                          Foreground="#10B981" HorizontalAlignment="Center"
                                          Margin="0,20,0,20"/>

                            <!-- Empty state -->
                            <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                                        HorizontalAlignment="Center" Margin="0,40,0,40">
                                <FontIcon Glyph="&#xE838;" FontSize="48" Foreground="#CBD5E1"/>
                                <TextBlock Text="No access logs found" FontSize="16"
                                           Foreground="#94A3B8" HorizontalAlignment="Center"
                                           Margin="0,12,0,4"/>
                                <TextBlock Text="Try adjusting your filters" FontSize="13"
                                           Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!--
                                DataTemplate uses {Binding} (classic binding) not {x:Bind}
                                because the list holds mixed objects (AccessLog + VisitorLog).
                                Both models expose the same property names:
                                ClientName, NIN, Floor, Date, TimeIn, TimeOut, Status,
                                Initials, RowType
                            -->
                            <ListView x:Name="AccessLogsList" SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding"          Value="0"/>
                                        <Setter Property="Margin"           Value="0,0,0,12"/>
                                        <Setter Property="BorderBrush"      Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness"  Value="1"/>
                                        <Setter Property="CornerRadius"     Value="12"/>
                                        <Setter Property="Background"       Value="White"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Padding="20,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <!-- avatar      -->
                                                <ColumnDefinition Width="2*"/>
                                                <!-- name block  -->
                                                <ColumnDefinition Width="1.3*"/>
                                                <!-- date        -->
                                                <ColumnDefinition Width="1.2*"/>
                                                <!-- time in     -->
                                                <ColumnDefinition Width="1.2*"/>
                                                <!-- time out    -->
                                                <ColumnDefinition Width="Auto"/>
                                                <!-- type+status -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar circle -->
                                            <Grid Grid.Column="0" VerticalAlignment="Center"
                                                  Margin="0,0,16,0">
                                                <Ellipse Width="44" Height="44" Fill="#ECFDF5"/>
                                                <TextBlock Text="{Binding Initials}"
                                                           Foreground="#10B981" FontWeight="Bold"
                                                           FontSize="14" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Name / NIN / Floor -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding ClientName}"
                                                           FontSize="15" FontWeight="Bold" Foreground="#0F172A"/>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="NIN:"  FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="{Binding NIN}" FontSize="12"
                                                               Foreground="#334155" FontWeight="Medium"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="Floor:" FontSize="12" Foreground="#64748B"/>
                                                    <TextBlock Text="{Binding Floor}" FontSize="12"
                                                               Foreground="#334155" FontWeight="Medium"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Date -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                        HorizontalAlignment="Left" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <FontIcon Glyph="&#xE787;" FontSize="14"
                                                              Foreground="#4F46E5" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Date}" FontSize="14"
                                                               FontWeight="SemiBold" Foreground="#1E293B"/>
                                                </StackPanel>
                                                <TextBlock Text="Date" FontSize="11" Foreground="#94A3B8"/>
                                            </StackPanel>

                                            <!-- Time In -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center"
                                                        HorizontalAlignment="Left" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <FontIcon Glyph="&#xE72A;" FontSize="14"
                                                              Foreground="#10B981" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding TimeIn}" FontSize="14"
                                                               FontWeight="SemiBold" Foreground="#1E293B"/>
                                                </StackPanel>
                                                <TextBlock Text="Time In" FontSize="11" Foreground="#94A3B8"/>
                                            </StackPanel>

                                            <!-- Time Out -->
                                            <StackPanel Grid.Column="4" VerticalAlignment="Center"
                                                        HorizontalAlignment="Left" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <FontIcon Glyph="&#xE72B;" FontSize="14"
                                                              Foreground="#EF4444" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding TimeOut}" FontSize="14"
                                                               FontWeight="SemiBold" Foreground="#1E293B"/>
                                                </StackPanel>
                                                <TextBlock Text="Time Out" FontSize="11" Foreground="#94A3B8"/>
                                            </StackPanel>

                                            <!-- Type badge + Status badge stacked -->
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center"
                                                        Spacing="6" HorizontalAlignment="Right">

                                                <!-- CLIENT (green) or VISITOR (blue) -->
                                                <Border CornerRadius="6" Padding="10,3"
                                                        HorizontalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#ECFDF5"/>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{Binding RowType}"
                                                                   FontSize="10" FontWeight="Bold"
                                                                   Foreground="#047857"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Status -->
                                                <Border Background="#ECFDF5" CornerRadius="12"
                                                        Padding="12,4" HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#059669"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Footer -->
                            <Grid Margin="0,16,0,0">
                                <TextBlock x:Name="EntriesLabel"
                                           Text="Showing 0 to 0 of 0 entries"
                                           FontSize="13" Foreground="#475569"
                                           VerticalAlignment="Center"/>
                                <StackPanel x:Name="PaginationPanel" Orientation="Horizontal"
                                            HorizontalAlignment="Right" Spacing="4"/>
                            </Grid>

                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>