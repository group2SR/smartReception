<Page
    x:Class="smartReception.Access_Control"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Page.Resources>
        <ThemeShadow x:Name="SharedShadow" />

        <Style TargetType="TextBlock" x:Key="HeaderTextStyle">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="Button" x:Key="SidebarButtonStyle">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style TargetType="Button" x:Key="ActiveSidebarButtonStyle" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Grid Grid.Column="0" Background="#0F172A" Padding="0,24,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="24,0,24,32" Spacing="8">
                <Image Source="/Assets/cemlogo_transparent.png" Height="45" HorizontalAlignment="Left"/>
                <TextBlock Text="CEMENTERS PLAZA" Foreground="#10B981" FontSize="11"
                           FontWeight="Bold" CharacterSpacing="100"/>
                <TextBlock Text="Desk Receptionist" Foreground="#64748B" FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Spacing="4" Padding="12,0">
                <StackPanel.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1E293B"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#10B981"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0F172A"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#10B981"/>
                </StackPanel.Resources>
                <Button Content="Dashboard" Click="NavDashboard_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="Access Logs" Click="NavAccessControl_Click" Style="{StaticResource ActiveSidebarButtonStyle}"/>
                <Button Content="General Reports" Click="NavReports_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="System Logs" Click="NavLogs_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="Receptionists" Click="NavReceptionists_Click" Style="{StaticResource SidebarButtonStyle}"/>
                <Button Content="Settings" Click="NavSettings_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Padding="12,0" Spacing="8">
                <Rectangle Height="1" Fill="#1E293B" Margin="0,0,0,12"/>
                <Button Content="Sign Out" Click="NavLogout_Click" Style="{StaticResource SidebarButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#059669"/>
                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#047857"/>
                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
            </Grid.Resources>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="White" Padding="32,20"
                  BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Access Logs" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="View and filter building entry and exit history for clients and visitors"
                               Foreground="#64748B" FontSize="13"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Padding="32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,16,0">
                    <StackPanel Spacing="24">
                        <Border Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Filter Access Logs" FontSize="18" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,20,16"/>

                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Search Entry" Style="{StaticResource HeaderTextStyle}"/>
                                        <TextBox x:Name="SearchBox" Foreground="Black" PlaceholderText="Search by name or NIN..." Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                        <TextBlock Text="Floor" Style="{StaticResource HeaderTextStyle}"/>
                                        <ComboBox x:Name="FloorCombo" PlaceholderText="All Floors" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Foreground="Black">
                                            <ComboBoxItem Content="All Floors" IsSelected="True" Foreground="Black"/>
                                            <ComboBoxItem Content="1st Floor" Foreground="Black"/>
                                            <ComboBoxItem Content="2nd Floor" Foreground="Black"/>
                                            <ComboBoxItem Content="3rd Floor" Foreground="Black"/>
                                            <ComboBoxItem Content="4th Floor" Foreground="Black"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                        <TextBlock Text="Date From" Style="{StaticResource HeaderTextStyle}"/>
                                        <CalendarDatePicker x:Name="DateFrom" Foreground="Black" PlaceholderText="dd/mm/yyyy" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Margin="0,0,16,0">
                                        <TextBlock Text="Date To" Style="{StaticResource HeaderTextStyle}"/>
                                        <CalendarDatePicker x:Name="DateTo" Foreground="Black" PlaceholderText="dd/mm/yyyy" HorizontalAlignment="Stretch" Height="40" CornerRadius="8" BorderBrush="#CBD5E1"/>
                                    </StackPanel>

                                    <Button Grid.Column="4" VerticalAlignment="Bottom" Height="40" Width="110" Background="#10B981" Foreground="White" CornerRadius="8" Click="SearchButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Filter" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <MenuFlyoutSeparator Background="#E2E8F0" Margin="0,0,0,16"/>

                                <ProgressRing x:Name="LoadingRing" IsActive="False" Visibility="Collapsed" Width="40" Height="40" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,20,0,20"/>

                                <StackPanel x:Name="EmptyState" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,40,0,40">
                                    <TextBlock Text="No access logs discovered" FontSize="16" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                    <TextBlock Text="Try resetting or altering selected parameters" FontSize="13" Foreground="#CBD5E1" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <ListView x:Name="AccessLogsList" SelectionMode="None" IsItemClickEnabled="True" ItemClick="AccessLogsList_ItemClick">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,12"/>
                                            <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="CornerRadius" Value="12"/>
                                            <Setter Property="Background" Value="White"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>

                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="16,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="1.3*"/>
                                                    <ColumnDefinition Width="1.3*"/>
                                                    <ColumnDefinition Width="1.3*"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,14,0">
                                                    <Ellipse Width="40" Height="40" Fill="#ECFDF5"/>
                                                    <TextBlock Text="{Binding Initials}" Foreground="#10B981" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                    <TextBlock Text="{Binding ClientName}" FontSize="14" FontWeight="Bold" Foreground="#0F172A"/>
                                                    <TextBlock Text="{Binding RowType}" FontSize="11" Foreground="#10B981" FontWeight="Medium"/>
                                                    <TextBlock Text="{Binding NIN}" FontSize="12" Foreground="#64748B"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
                                                    <TextBlock Text="{Binding Date}" FontSize="13" FontWeight="SemiBold" Foreground="#1E293B"/>
                                                    <TextBlock Text="{Binding Floor}" FontSize="12" Foreground="#64748B"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="1">
                                                    <TextBlock Text="{Binding TimeIn}" FontSize="13" FontWeight="SemiBold" Foreground="#10B981"/>
                                                    <TextBlock Text="Checked In" FontSize="11" Foreground="#94A3B8"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4" VerticalAlignment="Center" Spacing="1">
                                                    <TextBlock Text="{Binding TimeOut}" FontSize="13" FontWeight="SemiBold" Foreground="#EF4444"/>
                                                    <TextBlock Text="Checked Out" FontSize="11" Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="EntriesLabel" Text="Showing 0 entries" VerticalAlignment="Center" Foreground="#64748B" FontSize="13"/>
                                    <StackPanel x:Name="PaginationPanel" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" Margin="16,0,0,0" VerticalAlignment="Top">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Inspection Overview" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                        <MenuFlyoutSeparator Background="#E2E8F0"/>

                        <StackPanel Spacing="14">
                            <StackPanel>
                                <TextBlock Text="Contact Mobile" FontSize="11" Foreground="#64748B" FontWeight="Medium" Margin="0,0,0,2"/>
                                <TextBlock x:Name="CardPhone" Text="---" FontSize="14" Foreground="#1E293B" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Destination Target" FontSize="11" Foreground="#64748B" FontWeight="Medium" Margin="0,0,0,2"/>
                                <TextBlock x:Name="CardFloor" Text="---" FontSize="14" Foreground="#1E293B" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Identification (NIN)" FontSize="11" Foreground="#64748B" FontWeight="Medium" Margin="0,0,0,2"/>
                                <TextBlock x:Name="CardNIN" Text="---" FontSize="14" Foreground="#1E293B" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock x:Name="CardDateLabel" Text="Action Log Timestamp" FontSize="11" Foreground="#64748B" FontWeight="Medium" Margin="0,0,0,2"/>
                                <TextBlock x:Name="CardDateValue" Text="---" FontSize="14" Foreground="#1E293B" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>