<Page
    x:Class="smartReception.UsersReceptionist"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F8FAFC">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <StackPanel Padding="24" HorizontalAlignment="Stretch" Spacing="20">

            <TextBlock Text="Users (Receptionists)"
                       FontSize="28" FontWeight="Bold" Foreground="#0F172A"/>

            <!-- ── ADD / EDIT FORM ── -->
            <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">

                    <Grid>
                        <TextBlock x:Name="TxtFormTitle"
                                   Text="Add Receptionist"
                                   FontSize="16" FontWeight="Bold" Foreground="#0F172A"
                                   VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Background="#0066E2" Foreground="White"
                                CornerRadius="6" Padding="16,8" Click="BtnClear_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="12" Foreground="White"/>
                                <TextBlock Text="New Receptionist" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="First Name" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox x:Name="TxtFirstName" PlaceholderText="Enter first name"
                                     Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Last Name" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox x:Name="TxtLastName" PlaceholderText="Enter last name"
                                     Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Spacing="6">
                            <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox x:Name="TxtUsername" PlaceholderText="Enter username"
                                     Height="38" CornerRadius="6" BorderBrush="#CBD5E1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6" Spacing="6">
                            <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <PasswordBox x:Name="TxtPassword" PlaceholderText="Enter password"
                                         Height="38" CornerRadius="6" BorderBrush="#CBD5E1" PasswordChar="●"/>
                        </StackPanel>

                        <StackPanel Grid.Column="8" Spacing="6">
                            <TextBlock Text="Status" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <ComboBox x:Name="CboStatus" PlaceholderText="Select status"
                                      HorizontalAlignment="Stretch" Height="38"
                                      CornerRadius="6" BorderBrush="#CBD5E1">
                                <ComboBoxItem Content="Active"  Tag="false"/>
                                <ComboBoxItem Content="Blocked" Tag="true"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,4,0,0">
                        <Button x:Name="BtnSave" Content="Save"
                                Width="100" Height="36"
                                Background="#0066E2" Foreground="White"
                                FontWeight="SemiBold" CornerRadius="6"
                                Click="BtnSave_Click"/>
                        <Button Content="Clear"
                                Width="100" Height="36"
                                Background="#D2D6DC" Foreground="#1F2937"
                                FontWeight="SemiBold" CornerRadius="6"
                                Click="BtnClear_Click"/>
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ── USER LIST ── -->
            <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">

                    <!-- Search -->
                    <StackPanel Spacing="6" MaxWidth="360" HorizontalAlignment="Left">
                        <TextBlock Text="Search Receptionist" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                        <Grid>
                            <TextBox x:Name="TxtSearch"
                                     PlaceholderText="Search by name or username..."
                                     Height="38" CornerRadius="6" BorderBrush="#CBD5E1"
                                     Padding="10,6,36,6"
                                     TextChanged="TxtSearch_TextChanged"/>
                            <FontIcon Glyph="&#xE721;" FontSize="14" Foreground="#64748B"
                                      HorizontalAlignment="Right" Margin="0,0,12,0"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- Table -->
                    <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6">
                        <StackPanel>

                            <!-- Header row -->
                            <Grid Background="#F1F5F9" Padding="16,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="3.2*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="User ID"      FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="1" Text="Full Name"    FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="2" Text="Username"     FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="3" Text="Role"         FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="4" Text="Status"       FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="5" Text="Created Date" FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                                <TextBlock Grid.Column="6" Text="Actions"      FontSize="12" FontWeight="Bold" Foreground="#334155"/>
                            </Grid>

                            <!-- Data rows -->
                            <ListView x:Name="UsersListView"
                                      SelectionMode="None" IsItemClickEnabled="False" Padding="0">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="MinHeight" Value="52"/>
                                        <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:SystemUserDisplay">
                                        <Grid Padding="16,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="3.2*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{x:Bind UserId}"
                                                       FontSize="13" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind FullName}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind Username}"
                                                       FontSize="13" Foreground="#334155" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind RoleName}"
                                                       FontSize="13" Foreground="#334155" VerticalAlignment="Center"/>

                                            <!-- Status badge -->
                                            <Border Grid.Column="4"
                                                    Background="{x:Bind StatusBadgeBg}"
                                                    BorderBrush="{x:Bind StatusBadgeBorder}"
                                                    BorderThickness="0.5" CornerRadius="12"
                                                    Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind StatusLabel}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{x:Bind StatusBadgeText}"/>
                                            </Border>

                                            <TextBlock Grid.Column="5" Text="{x:Bind CreatedDate}"
                                                       FontSize="13" Foreground="#334155" VerticalAlignment="Center"/>

                                            <!-- Action buttons -->
                                            <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Button Background="#0066E2" Foreground="White"
                                                        CornerRadius="4" Padding="10,6" Height="30"
                                                        CommandParameter="{x:Bind UserId}"
                                                        Click="BtnEdit_Click">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE70F;" FontSize="11" Foreground="White"/>
                                                        <TextBlock Text="Edit" FontSize="12" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Background="#F59E0B" Foreground="White"
                                                        CornerRadius="4" Padding="10,6" Height="30"
                                                        CommandParameter="{x:Bind UserId}"
                                                        Click="BtnBlock_Click">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xF140;" FontSize="11" Foreground="White"/>
                                                        <TextBlock Text="{x:Bind BlockLabel}" FontSize="12" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Button>

                                                <Button Background="#DC2626" Foreground="White"
                                                        CornerRadius="4" Padding="10,6" Height="30"
                                                        CommandParameter="{x:Bind UserId}"
                                                        Click="BtnDelete_Click">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <FontIcon Glyph="&#xE74D;" FontSize="11" Foreground="White"/>
                                                        <TextBlock Text="Delete" FontSize="12" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="TxtEntryCount" Text="Showing 0 entries"
                               FontSize="13" Foreground="#475569"/>

                </StackPanel>
            </Border>

            <!-- Navigation -->
            <Button Content="Settings"
                    Background="#0066E2" Foreground="White"
                    Width="100" Height="50"
                    x:Name="Settingspagbtn" Click="Settingspagbtn_Click"/>

            <AppBarButton Icon="Back" Background="#0066E2" Foreground="White"
                          HorizontalAlignment="Left" Margin="0,8,0,0" CornerRadius="10"
                          x:Name="userreceptionsbackbtn" Click="userreceptionsbackbtn_Click"/>

        </StackPanel>
    </ScrollViewer>
</Page>
