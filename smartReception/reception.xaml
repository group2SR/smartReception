<Page
    x:Class="smartReception.reception"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#F1F5F9">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0.0"/>
                <GradientStop Color="#064E3B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="900"
              Width="Auto">

            <Border BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="48,40"
                    Background="#F8FAFC">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>

                <Grid ColumnSpacing="60">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="340" />
                    </Grid.ColumnDefinitions>

                    <!-- Left Column: Go back to Admin Gateway -->
                    <StackPanel Grid.Column="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="20">

                        <Image Source="/Assets/cemlogo_transparent.png"
                               Height="70"
                               Width="210"
                               HorizontalAlignment="Center"/>

                        <Grid CornerRadius="12"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1.5" 
                              Tapped="Grid_Tapped" 
                              PointerEntered="Grid_PointerEntered" 
                              PointerExited="Grid_PointerExited"
                              Background="White"
                              Padding="24">
                            <StackPanel Spacing="12">
                                <Image Source="/Assets/admin_logo_transparent.png"
                                       Height="140"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>

                                <TextBlock Text="ADMIN GATEWAY"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           TextAlignment="Center"
                                           Foreground="#0F172A"/>

                                <TextBlock Text="Tap here to return to administrator access"
                                           TextAlignment="Center"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Width="1.5" Fill="#E2E8F0" Margin="0,10"/>

                    <!-- Right Column: Receptionist Login Form -->
                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="340"
                                Spacing="18">

                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <Image Source="/Assets/Admin and receptionist logo designs.png"
                                   Height="80"
                                   Margin="0,0,0,10"
                                   HorizontalAlignment="Center"/>

                            <TextBlock Text="RECEPTION DESK"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Foreground="#059669"
                                       TextAlignment="Center"
                                       CharacterSpacing="100"/>

                            <TextBlock Text="Receptionist Sign In"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       Foreground="#0F172A"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <TextBox x:Name="TxtUsername" PlaceholderText="Enter username" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Padding="10,0" VerticalContentAlignment="Center" Foreground="Black"/>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                            <PasswordBox x:Name="TxtPassword" PlaceholderText="Enter password" Height="40" CornerRadius="8" BorderBrush="#CBD5E1" Padding="10,0" VerticalContentAlignment="Center" Foreground="Black"/>
                        </StackPanel>

                        <Button Content="Sign In to Reception"
                                HorizontalAlignment="Stretch"
                                Height="45"
                                Background="#059669"
                                Foreground="White"
                                CornerRadius="8"
                                FontWeight="Bold"
                                x:Name="ReceptionistLogin" Click="ReceptionistLogin_Click"/>

                        <TextBlock Text=""
                                   x:Name="comment"
                                   TextAlignment="Center"
                                   Foreground="#DC2626"
                                   FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
