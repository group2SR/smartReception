<Page
    x:Class="smartReception.reception"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:smartReception"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/b2.png "/>
        </Grid.Background>
        <Grid HorizontalAlignment="Center"
  VerticalAlignment="Center"
  MaxWidth="900"
  Width="Auto"
      >

            
            <Border BorderBrush="Green"
        BorderThickness="2"
        CornerRadius="10"
        Padding="20"
        Background="White"
            >

                
                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    
                    <StackPanel Grid.Column="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="10">

                        <Image Source="/Assets/cemlogo_transparent.png"
                   Height="80"
                   Margin="0,1"
                       Width="220"/>
                        <Grid CornerRadius="6"
                  BorderBrush="LimeGreen"
                  BorderThickness="1" Tapped="Grid_Tapped" PointerEntered="Grid_PointerEntered" PointerExited="Grid_PointerExited"
                              Background="#d5d7de"
                              >
                            <StackPanel>
                                <Image Source="/Assets/admin_logo_transparent.png"
                   Height="150"
                   Stretch="Uniform"
                   Margin="0,10"/>

                                <TextBlock Text="ADMIN"
                       FontSize="18"
                       TextAlignment="Center"
                       Margin="10"/>

                                <TextBlock Text="Tap here to access administration"
                       TextAlignment="Center"
                           Margin="0,15"/>
                            </StackPanel>
                        </Grid>



                    </StackPanel>

                    
                    <StackPanel Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="10"
                   Width="300">

                        <Image Source="/Assets/Admin and receptionist logo designs.png"
                   Height="80"
                   Margin="0,10"/>

                        <TextBlock Text="Enter receprionist details"
                       FontSize="12"
                       TextAlignment="Center"
                           FontWeight="SemiLight"/>

                        <TextBox PlaceholderText="Enter Name"
                     Header="Name"/>

                        <TextBox PlaceholderText="Enter Password"
                     Header="Password"
                     Margin="0,15"/>

                        <Button Content="Enter"
                    HorizontalAlignment="Center"
                    Margin="10" Width="140"
                                Background="LimeGreen"
                                CornerRadius="5"/>

                        <TextBlock Text="ue"
                       x:Name="comment"
                       TextAlignment="Center"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</Page>
